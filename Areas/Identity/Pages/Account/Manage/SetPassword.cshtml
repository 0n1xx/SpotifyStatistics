@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Set password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

@* Set password — shown when user signed up via OAuth and has no local password yet *@

<section class="m-section" aria-labelledby="set-password-heading">
    <h2 id="set-password-heading" class="m-section-title">Set your password</h2>
    <article class="m-card">
        <div class="m-row m-row--col">
            <div class="m-row-info">
                <p class="m-row-label">Add a local password</p>
                <p class="m-row-desc">
                    You don't have a local password yet. Add one so you can sign in
                    without an external login provider.
                </p>
            </div>
            <div class="m-row-action m-row-action--col">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="m-alert m-alert-error m-form-summary"></div>
                    <div class="m-form-stack">

                        @* New password *@
                        <div class="m-form-group">
                            <label asp-for="Input.NewPassword">New password</label>
                            <input asp-for="Input.NewPassword"
                                   class="m-input"
                                   placeholder="••••••••"
                                   autocomplete="new-password">
                            <span asp-validation-for="Input.NewPassword" class="m-field-error"></span>
                        </div>

                        @* Confirm password *@
                        <div class="m-form-group">
                            <label asp-for="Input.ConfirmPassword">Confirm password</label>
                            <input asp-for="Input.ConfirmPassword"
                                   class="m-input"
                                   placeholder="••••••••"
                                   autocomplete="new-password">
                            <span asp-validation-for="Input.ConfirmPassword" class="m-field-error"></span>
                        </div>

                        <button type="submit" class="m-btn m-btn-green m-btn-submit">
                            Set password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
