@page
@model EmailModel
@{
    ViewData["Title"] = "Manage Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

@* Email manage page — current email, verification status, change email *@

<div class="m-section">
    <h2 class="m-section-title">Current email</h2>
    <div class="m-card">

        @* Current email row with verification badge *@
        <div class="m-row" style="flex-wrap:wrap;">
            <div class="m-row-info">
                <p class="m-row-label">Email address</p>
                <p class="m-row-desc">
                    @Model.Email
                    @if (Model.IsEmailConfirmed)
                    {
                        <span class="m-badge m-badge-green" style="margin-left:8px; vertical-align:middle;">
                            @* checkmark icon *@
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                            Verified
                        </span>
                    }
                    else
                    {
                        <span class="m-badge m-badge-muted" style="margin-left:8px; vertical-align:middle;">Unverified</span>
                    }
                </p>
            </div>
            @if (!Model.IsEmailConfirmed)
            {
                @* Only show re-send button if email isn't verified yet *@
                <div class="m-row-action">
                    <form id="send-verification-form" method="post" asp-page-handler="SendVerificationEmail">
                        <button type="submit" class="m-btn m-btn-outline">Send verification email</button>
                    </form>
                </div>
            }
        </div>

    </div>
</div>

<div class="m-section" style="animation-delay:0.05s;">
    <h2 class="m-section-title">Change email</h2>
    <div class="m-card">
        <div class="m-row" style="flex-direction:column; align-items:stretch; gap:16px;">
            <form id="change-email-form" method="post" asp-page-handler="ChangeEmail">
                <div asp-validation-summary="ModelOnly" class="m-alert m-alert-error" style="margin-bottom:12px;"></div>
                <div style="display:flex; flex-direction:column; gap:12px;">
                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label asp-for="Input.NewEmail"
                               style="font-size:12px; font-weight:500; color:var(--muted2); text-transform:uppercase; letter-spacing:0.05em;">
                            New email address
                        </label>
                        <input asp-for="Input.NewEmail"
                               placeholder="new@example.com"
                               autocomplete="email"
                               style="background:#1a1a1a; border:1px solid var(--border); border-radius:10px; padding:12px 14px; font-size:14px; font-family:'DM Sans',sans-serif; color:var(--text); outline:none; width:100%; max-width:380px; transition:border-color 0.2s;"
                               onfocus="this.style.borderColor='var(--green)'"
                               onblur="this.style.borderColor='var(--border)'">
                        <span asp-validation-for="Input.NewEmail" class="text-danger" style="font-size:12px;"></span>
                    </div>
                    <button type="submit" class="m-btn m-btn-green" style="align-self:flex-start;">Change email</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
