@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

@* Change password page — current password + new password fields *@

<div class="m-section">
    <h2 class="m-section-title">Update password</h2>
    <div class="m-card">
        <div class="m-row" style="flex-direction:column; align-items:stretch; gap:16px;">

            @* Success alert from TempData — shown after password change *@
            @if (TempData["StatusMessage"] != null)
            {
                <div class="m-alert m-alert-success">@TempData["StatusMessage"]</div>
            }

            <form id="change-password-form" method="post">
                <div asp-validation-summary="ModelOnly" class="m-alert m-alert-error" style="margin-bottom:12px;"></div>
                <div style="display:flex; flex-direction:column; gap:14px; max-width:400px;">

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label asp-for="Input.OldPassword"
                               style="font-size:12px; font-weight:500; color:var(--muted2); text-transform:uppercase; letter-spacing:0.05em;">
                            Current password
                        </label>
                        <input asp-for="Input.OldPassword"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               style="background:#1a1a1a; border:1px solid var(--border); border-radius:10px; padding:12px 14px; font-size:14px; font-family:'DM Sans',sans-serif; color:var(--text); outline:none; width:100%; transition:border-color 0.2s;"
                               onfocus="this.style.borderColor='var(--green)'"
                               onblur="this.style.borderColor='var(--border)'">
                        <span asp-validation-for="Input.OldPassword" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label asp-for="Input.NewPassword"
                               style="font-size:12px; font-weight:500; color:var(--muted2); text-transform:uppercase; letter-spacing:0.05em;">
                            New password
                        </label>
                        <input asp-for="Input.NewPassword"
                               placeholder="Min. 6 characters"
                               autocomplete="new-password"
                               style="background:#1a1a1a; border:1px solid var(--border); border-radius:10px; padding:12px 14px; font-size:14px; font-family:'DM Sans',sans-serif; color:var(--text); outline:none; width:100%; transition:border-color 0.2s;"
                               onfocus="this.style.borderColor='var(--green)'"
                               onblur="this.style.borderColor='var(--border)'">
                        <span asp-validation-for="Input.NewPassword" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label asp-for="Input.ConfirmPassword"
                               style="font-size:12px; font-weight:500; color:var(--muted2); text-transform:uppercase; letter-spacing:0.05em;">
                            Confirm new password
                        </label>
                        <input asp-for="Input.ConfirmPassword"
                               placeholder="••••••••"
                               autocomplete="new-password"
                               style="background:#1a1a1a; border:1px solid var(--border); border-radius:10px; padding:12px 14px; font-size:14px; font-family:'DM Sans',sans-serif; color:var(--text); outline:none; width:100%; transition:border-color 0.2s;"
                               onfocus="this.style.borderColor='var(--green')'"
                               onblur="this.style.borderColor='var(--border)'">
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:12px;"></span>
                    </div>

                    <button type="submit" class="m-btn m-btn-green" style="align-self:flex-start; margin-top:4px;">Update password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
