@* _ManageLayout.cshtml — Shared layout for ASP.NET Identity Manage sub-pages
   (Profile, Email, Password, External logins, 2FA, Personal data)

   Changes from original:
   - Inline <style> block extracted to /wwwroot/css/manage.css
   - Hamburger button + JS drawer for mobile / tablet
   - Avatar image support in sidebar user card (mirrors Settings page)
   - CSS variables sourced from app.css (single source of truth)
*@
@inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);

    /* ── Spotify connection check ── */
    var hasSpotify = false;
    var config = ViewContext.HttpContext.RequestServices.GetRequiredService<IConfiguration>();
    var spotifyConn = config.GetConnectionString("DefaultConnection");
    try
    {
        using var sc = new Microsoft.Data.SqlClient.SqlConnection(spotifyConn);
        await sc.OpenAsync();
        using var scmd = new Microsoft.Data.SqlClient.SqlCommand(
            "SELECT COUNT(*) FROM SpotifyTokens WHERE UserId = @uid", sc);
        scmd.Parameters.AddWithValue("@uid", UserManager.GetUserId(User));
        hasSpotify = (int)(await scmd.ExecuteScalarAsync() ?? 0) > 0;
    }
    catch { }

    /* ── Avatar URL ──
       IdentityUser has no .Claims property — read the avatar file from disk instead,
       using the same logic as Settings.cshtml.cs OnGetAsync so the sidebar user card
       always shows the correct photo. */
    string? avatarUrl = null;
    var userName    = user?.UserName ?? "";
    var userInitial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "?";

    if (user != null)
    {
        var env        = ViewContext.HttpContext.RequestServices.GetRequiredService<IWebHostEnvironment>();
        var userId     = UserManager.GetUserId(User) ?? "";
        var avatarsDir = System.IO.Path.Combine(env.WebRootPath, "avatars");
        foreach (var ext in new[] { "jpg", "jpeg", "png", "gif", "webp" })
        {
            var candidate = System.IO.Path.Combine(avatarsDir, $"{userId}.{ext}");
            if (System.IO.File.Exists(candidate))
            {
                avatarUrl = $"/avatars/{userId}.{ext}";
                break;
            }
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Statify</title>

    @* Google Fonts — same as _AppLayout.cshtml *@
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    @* Global app shell (sidebar, grid, tokens, animations, responsive drawer) *@
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    @* Manage-page styles (Bootstrap overrides, tabs, responsive rules) *@
    <link rel="stylesheet" href="~/css/manage.css" asp-append-version="true" />

    @* Bootstrap — required by Identity Razor pages *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>

    @* ── Hamburger — hidden on desktop, visible ≤ 900px ── *@
    <button class="hamburger" id="hamburger-btn"
            aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>

    @* ── Overlay — dims the content behind the sidebar drawer on mobile ── *@
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <div class="app">

        @* ── Sidebar ── *@
        <aside class="sidebar" id="sidebar">

            @* Logo *@
            <a class="sidebar-logo" asp-page="/Index" asp-area="">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" />
                    </svg>
                </div>
                <span class="logo-text">Statify</span>
            </a>

            <nav class="nav" aria-label="Main navigation">

                <div class="nav-label">Menu</div>

                <a class="nav-item" asp-page="/Dashboard" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" /></svg>
                    Dashboard
                </a>

                <a class="nav-item" asp-page="/RecentlyPlayed" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" /></svg>
                    Recently Played
                </a>

                <a class="nav-item" asp-page="/WorldMap" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                    World Map
                </a>

                <div class="nav-label">Spotify</div>

                @if (!hasSpotify)
                {
                    <a class="nav-item" href="/SpotifyAuth/login"
                       style="color:#1DB954;border:1px solid rgba(29,185,84,0.2);background:rgba(29,185,84,0.05)">
                        <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        Connect Spotify
                    </a>
                }
                else
                {
                    <div class="nav-connected">
                        <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        <span style="font-size:13px">Spotify connected</span>
                        <div class="pulse-dot" style="margin-left:auto"></div>
                    </div>
                }

                <div class="nav-label">Account</div>

                <a class="nav-item active" asp-page="/Settings" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" /></svg>
                    Settings
                </a>

                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                    <button type="submit" class="nav-item"
                            style="width:100%;border:none;background:none;text-align:left;cursor:pointer">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" /></svg>
                        Sign out
                    </button>
                </form>

            </nav>

            @* ── User card ──
               Shows the uploaded profile photo if set; otherwise shows the first
               letter of the username as a green avatar — identical to the Settings
               page profile section so they always match.
            *@
            <a class="sidebar-user" asp-page="/Settings" asp-area="">
                <div class="user-avatar">
                    @if (avatarUrl != null)
                    {
                        <img src="@avatarUrl" alt="Profile photo">
                    }
                    else
                    {
                        @userInitial
                    }
                </div>
                <div>
                    <div class="user-name">@userName</div>
                    <div class="user-sub">Account settings</div>
                </div>
            </a>

        </aside>

        @* ── Page content ── *@
        <main class="main">

            <div class="page-header">
                <h1 class="page-title">@ViewData["Title"]</h1>
                <p class="page-sub">Manage your account settings</p>
            </div>

            <div>
                @* ── Manage sub-page tab bar ──
                   Horizontally scrollable on narrow screens via overflow-x:auto in manage.css.
                   Active tab underlined with Spotify green. *@
                <nav class="manage-tabs" aria-label="Account settings sections">

                    <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/Index") == true ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/Index">Profile</a>

                    <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/Email") == true ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/Email">Email</a>

                    <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/ChangePassword") == true ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Password</a>

                    <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/ExternalLogins") == true ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/ExternalLogins">Linked accounts</a>

                    <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/TwoFactorAuthentication") == true ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication">Two-factor</a>

                    <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/PersonalData") == true ? "active" : "")"
                       asp-area="Identity" asp-page="/Account/Manage/PersonalData">Personal data</a>

                </nav>

                @RenderBody()
            </div>

        </main>

    </div>

    @* Bootstrap JS — required by Identity Razor pages for validation *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @* ── Mobile hamburger / sidebar drawer ──
       Shared logic — identical to the script in _AppLayout.cshtml.
       Inlined here because _ManageLayout does not extend _AppLayout. *@
    <script src="~/js/sidebar.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
