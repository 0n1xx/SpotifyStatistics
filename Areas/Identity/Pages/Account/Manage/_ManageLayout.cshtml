@inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var hasSpotify = false;
    var config = ViewContext.HttpContext.RequestServices.GetRequiredService<IConfiguration>();
    var spotifyConn = config.GetConnectionString("DefaultConnection");
    try
    {
        using var sc = new Microsoft.Data.SqlClient.SqlConnection(spotifyConn);
        await sc.OpenAsync();
        using var scmd = new Microsoft.Data.SqlClient.SqlCommand("SELECT COUNT(*) FROM SpotifyTokens WHERE UserId = @uid", sc);
        scmd.Parameters.AddWithValue("@uid", UserManager.GetUserId(User));
        hasSpotify = (int)(await scmd.ExecuteScalarAsync() ?? 0) > 0;
    }
    catch { }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Statify</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --green: #1DB954; --green-dim: #17a349; --green-glow: rgba(29,185,84,0.15);
            --black: #080808; --card: #111111; --card2: #161616;
            --border: rgba(255,255,255,0.07); --text: #f0f0f0;
            --muted: #555; --muted2: #888; --sidebar: 240px;
        }
        html, body { height: 100%; background: var(--black); color: var(--text); font-family: 'DM Sans', sans-serif; overflow: hidden; }
        .app { display: grid; grid-template-columns: var(--sidebar) 1fr; height: 100vh; }
        /* Sidebar */
        .sidebar { background: #0c0c0c; border-right: 1px solid var(--border); display: flex; flex-direction: column; padding: 28px 0; overflow-y: auto; }
        .sidebar-logo { display: flex; align-items: center; gap: 10px; padding: 0 24px 28px; border-bottom: 1px solid var(--border); text-decoration: none; color: var(--text); }
        .logo-icon { width: 34px; height: 34px; background: var(--green); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .logo-icon svg { width: 18px; height: 18px; fill: #000; }
        .logo-text { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; letter-spacing: -0.5px; }
        .nav { padding: 20px 12px; flex: 1; }
        .nav-label { font-size: 10px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); padding: 0 12px; margin-bottom: 8px; margin-top: 20px; }
        .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; font-size: 14px; color: var(--muted2); cursor: pointer; transition: all 0.15s; text-decoration: none; margin-bottom: 2px; }
        .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.6; }
        .nav-item:hover { background: var(--card); color: var(--text); }
        .nav-item:hover svg { opacity: 1; }
        .nav-item.active { background: var(--green-glow); color: var(--green); font-weight: 500; }
        .nav-item.active svg { opacity: 1; }
        .nav-connected { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; font-size: 14px; color: var(--green); margin-bottom: 2px; }
        .nav-connected svg { width: 16px; height: 16px; flex-shrink: 0; }
        .pulse-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 2s ease-in-out infinite; }
        .sidebar-user { margin: 0 12px; padding: 12px; background: var(--card); border-radius: 10px; border: 1px solid var(--border); display: flex; align-items: center; gap: 10px; text-decoration: none; cursor: pointer; transition: border-color 0.15s; }
        .sidebar-user:hover { border-color: rgba(255,255,255,0.15); }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--green); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #000; flex-shrink: 0; }
        .user-name { font-size: 13px; font-weight: 500; color: var(--text); }
        .user-sub { font-size: 11px; color: var(--muted2); }
        /* Main */
        .main { overflow-y: auto; padding: 32px 40px; display: flex; flex-direction: column; gap: 28px; }
        .page-header { padding-bottom: 24px; border-bottom: 1px solid var(--border); }
        .page-title { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; letter-spacing: -0.5px; margin-bottom: 4px; }
        .page-sub { font-size: 14px; color: var(--muted2); }
        /* Manage tabs */
        .manage-tabs { display: flex; gap: 4px; border-bottom: 1px solid var(--border); padding-bottom: 0; margin-bottom: 28px; }
        .manage-tab { padding: 10px 16px; font-size: 13px; font-weight: 500; color: var(--muted2); text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.15s; }
        .manage-tab:hover { color: var(--text); }
        .manage-tab.active { color: var(--green); border-bottom-color: var(--green); }
        /* Override Bootstrap for dark theme */
        .form-floating label { color: var(--muted2); }
        .form-control { background: #1a1a1a !important; border: 1px solid var(--border) !important; color: var(--text) !important; border-radius: 10px !important; padding: 13px 16px !important; font-family: 'DM Sans', sans-serif !important; }
        .form-control:focus { border-color: var(--green) !important; box-shadow: none !important; background: #1a1a1a !important; }
        .form-control:disabled, .form-control[readonly] { background: #131313 !important; opacity: 0.7; }
        .form-floating > .form-control { padding-top: 1.625rem !important; padding-bottom: 0.625rem !important; }
        .form-floating > label { color: var(--muted2) !important; }
        .btn-primary { background: var(--green) !important; border-color: var(--green) !important; color: #000 !important; font-weight: 600; border-radius: 10px; font-family: 'DM Sans', sans-serif; padding: 12px 24px; transition: background 0.2s; }
        .btn-primary:hover { background: var(--green-dim) !important; border-color: var(--green-dim) !important; }
        .btn-secondary { background: var(--card2) !important; border-color: var(--border) !important; color: var(--text) !important; border-radius: 10px; font-family: 'DM Sans', sans-serif; padding: 12px 24px; }
        .btn-danger { background: rgba(231,76,60,0.15) !important; border-color: rgba(231,76,60,0.3) !important; color: #e74c3c !important; border-radius: 10px; font-family: 'DM Sans', sans-serif; }
        .btn-danger:hover { background: rgba(231,76,60,0.25) !important; }
        .alert-success { background: rgba(29,185,84,0.1) !important; border-color: rgba(29,185,84,0.25) !important; color: var(--green) !important; border-radius: 10px; }
        .alert-danger { background: rgba(231,76,60,0.1) !important; border-color: rgba(231,76,60,0.3) !important; color: #e74c3c !important; border-radius: 10px; }
        .alert-warning { background: rgba(240,180,41,0.1) !important; border-color: rgba(240,180,41,0.25) !important; color: #f0b429 !important; border-radius: 10px; }
        .text-danger { color: #e74c3c !important; font-size: 12px; }
        .text-success { color: var(--green) !important; }
        .text-muted { color: var(--muted2) !important; }
        h1, h2, h3, h4 { font-family: 'Syne', sans-serif; font-weight: 700; }
        p { color: var(--muted2); font-size: 14px; line-height: 1.6; }
        hr { border-color: var(--border); }
        table { color: var(--text); }
        .table { color: var(--text); border-color: var(--border); }
        .table thead th { border-color: var(--border); color: var(--muted2); font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; }
        .table td { border-color: rgba(255,255,255,0.04); vertical-align: middle; }
        .badge { border-radius: 20px; font-weight: 500; }
        .main::-webkit-scrollbar { width: 4px; }
        .main::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
        @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
    </style>
</head>
<body>
<div class="app">
    <aside class="sidebar">
        <a class="sidebar-logo" asp-page="/Index" asp-area="">
            <div class="logo-icon">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
            </div>
            <span class="logo-text">Statify</span>
        </a>
        <nav class="nav">
            <div class="nav-label">Menu</div>
            <a class="nav-item" asp-page="/Dashboard" asp-area="">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" /></svg>
                Dashboard
            </a>
            <a class="nav-item" asp-page="/RecentlyPlayed" asp-area="">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" /></svg>
                Recently Played
            </a>
            <a class="nav-item" asp-page="/WorldMap" asp-area="">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                World Map
            </a>
            <div class="nav-label">Spotify</div>
            @if (!hasSpotify)
            {
                <a class="nav-item" href="/SpotifyAuth/login" style="color:#1DB954;border:1px solid rgba(29,185,84,0.2);background:rgba(29,185,84,0.05)">
                    <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                    Connect Spotify
                </a>
            }
            else
            {
                <div class="nav-connected">
                    <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                    <span style="font-size:13px">Spotify connected</span>
                    <div class="pulse-dot" style="margin-left:auto"></div>
                </div>
            }
            <div class="nav-label">Account</div>
            <a class="nav-item active" asp-page="/Settings" asp-area="">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" /></svg>
                Settings
            </a>
            <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                <button type="submit" class="nav-item" style="width:100%;border:none;background:none;text-align:left;cursor:pointer">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" /></svg>
                    Sign out
                </button>
            </form>
        </nav>
        <a class="sidebar-user" asp-page="/Settings" asp-area="">
            <div class="user-avatar">@(user?.UserName?.Substring(0, 1).ToUpper() ?? "?")</div>
            <div>
                <div class="user-name">@user?.UserName</div>
                <div class="user-sub">Account settings</div>
            </div>
        </a>
    </aside>

    <main class="main">
        <div class="page-header">
            <h1 class="page-title">@ViewData["Title"]</h1>
            <p class="page-sub">Manage your account settings</p>
        </div>

        <div>
            <nav class="manage-tabs">
                <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/Index") == true ? "active" : "")"
                   asp-area="Identity" asp-page="/Account/Manage/Index">Profile</a>
                <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/Email") == true ? "active" : "")"
                   asp-area="Identity" asp-page="/Account/Manage/Email">Email</a>
                <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/ChangePassword") == true ? "active" : "")"
                   asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Password</a>
                <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/ExternalLogins") == true ? "active" : "")"
                   asp-area="Identity" asp-page="/Account/Manage/ExternalLogins">Linked accounts</a>
                <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/TwoFactorAuthentication") == true ? "active" : "")"
                   asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication">Two-factor</a>
                <a class="manage-tab @(ViewContext.RouteData.Values["page"]?.ToString()?.EndsWith("/PersonalData") == true ? "active" : "")"
                   asp-area="Identity" asp-page="/Account/Manage/PersonalData">Personal data</a>
            </nav>

            @RenderBody()
        </div>
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
