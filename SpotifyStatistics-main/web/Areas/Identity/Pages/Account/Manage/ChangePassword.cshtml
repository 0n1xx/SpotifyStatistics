@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

@* Change password — three input fields: current, new, confirm *@

<section class="m-section" aria-labelledby="change-password-heading">
    <h2 id="change-password-heading" class="m-section-title">Change password</h2>
    <article class="m-card">
        <div class="m-row m-row--col">
            <div class="m-row-info">
                <p class="m-row-label">Update your password</p>
                <p class="m-row-desc">Choose a strong password you don't use anywhere else.</p>
            </div>
            <div class="m-row-action m-row-action--col">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="m-alert m-alert-error m-form-summary"></div>
                    <div class="m-form-stack">

                        @* Current password *@
                        <div class="m-form-group">
                            <label asp-for="Input.OldPassword">Current password</label>
                            <input asp-for="Input.OldPassword"
                                   class="m-input"
                                   placeholder="••••••••"
                                   autocomplete="current-password">
                            <span asp-validation-for="Input.OldPassword" class="m-field-error"></span>
                        </div>

                        @* New password *@
                        <div class="m-form-group">
                            <label asp-for="Input.NewPassword">New password</label>
                            <input asp-for="Input.NewPassword"
                                   class="m-input"
                                   placeholder="••••••••"
                                   autocomplete="new-password">
                            <span asp-validation-for="Input.NewPassword" class="m-field-error"></span>
                        </div>

                        @* Confirm new password *@
                        <div class="m-form-group">
                            <label asp-for="Input.ConfirmPassword">Confirm new password</label>
                            <input asp-for="Input.ConfirmPassword"
                                   class="m-input"
                                   placeholder="••••••••"
                                   autocomplete="new-password">
                            <span asp-validation-for="Input.ConfirmPassword" class="m-field-error"></span>
                        </div>

                        <button type="submit" class="m-btn m-btn-green m-btn-submit">
                            Update password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
