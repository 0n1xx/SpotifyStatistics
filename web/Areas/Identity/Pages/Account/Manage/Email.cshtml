@page
@model EmailModel
@{
    ViewData["Title"] = "Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

@* Email manage page — shows current email + change email form *@

<section class="m-section" aria-labelledby="current-email-heading">
    <h2 id="current-email-heading" class="m-section-title">Email address</h2>
    <article class="m-card">

        @* Current email — read-only display with verified/unverified badge *@
        <div class="m-row m-row--wrap">
            <div class="m-row-info">
                <p class="m-row-label">Current email</p>
                <p class="m-row-desc">Your login email and notification address.</p>
            </div>
            <div class="m-row-action">
                <span class="m-value-badge">@Model.Email</span>
                @if (Model.IsEmailConfirmed)
                {
                    <span class="m-badge m-badge-green m-badge--inline">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                        </svg>
                        Verified
                    </span>
                }
                else
                {
                    <span class="m-badge m-badge-muted m-badge--inline">Unverified</span>
                }
            </div>
        </div>

    </article>
</section>

@* Change email form *@
<section class="m-section m-section--delay-sm" aria-labelledby="change-email-heading">
    <h2 id="change-email-heading" class="m-section-title">Change email</h2>
    <article class="m-card">
        <div class="m-row m-row--col">
            <div class="m-row-info">
                <p class="m-row-label">New email address</p>
                <p class="m-row-desc">Enter a new email to update your login address.</p>
            </div>
            <div class="m-row-action m-row-action--col">
                <form method="post" asp-page-handler="ChangeEmail">
                    <div asp-validation-summary="ModelOnly" class="m-alert m-alert-error m-form-summary"></div>
                    <div class="m-form-stack">
                        <div class="m-form-group">
                            <label asp-for="Input.NewEmail">New email</label>
                            <input asp-for="Input.NewEmail"
                                   class="m-input"
                                   placeholder="you@example.com"
                                   autocomplete="email">
                            <span asp-validation-for="Input.NewEmail" class="m-field-error"></span>
                        </div>
                        <button type="submit" class="m-btn m-btn-green m-btn-submit">
                            Change email
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
