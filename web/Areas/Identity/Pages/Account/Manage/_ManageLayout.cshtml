@* =============================================================
   _ManageLayout.cshtml — Shared layout for ASP.NET Identity Manage sub-pages
   (Profile, Email, Password, External logins, Personal data)

   What this file does:
   - Builds the full HTML shell (head + sidebar + main) for manage pages
   - Loads app.css (global tokens + sidebar + responsive drawer)
   - Loads manage.css (manage-specific styles, Bootstrap overrides, dark theme)
   - Renders the hamburger button + overlay for the mobile sidebar drawer
   - Checks Spotify connection and resolves the avatar URL from disk
   - Shows the correct tab as active using the current Razor route
   - Two-factor tab is intentionally removed (not supported in this app)
   ============================================================= *@
@inject Microsoft.AspNetCore.Identity.SignInManager<Microsoft.AspNetCore.Identity.IdentityUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);

    /* ── Spotify connection ──────────────────────────────────────
       Query the SpotifyTokens table.  Wrapped in try/catch so the
       page still renders even if the DB is unreachable. */
    var hasSpotify = false;
    var config     = ViewContext.HttpContext.RequestServices.GetRequiredService<IConfiguration>();
    var connStr    = config.GetConnectionString("DefaultConnection");
    try
    {
        using var sc = new Microsoft.Data.SqlClient.SqlConnection(connStr);
        await sc.OpenAsync();
        using var scmd = new Microsoft.Data.SqlClient.SqlCommand(
            "SELECT COUNT(*) FROM SpotifyTokens WHERE UserId = @uid", sc);
        scmd.Parameters.AddWithValue("@uid", UserManager.GetUserId(User));
        hasSpotify = (int)(await scmd.ExecuteScalarAsync() ?? 0) > 0;
    }
    catch { /* silently ignore — site still works without Spotify status */ }

    /* ── Avatar URL ──────────────────────────────────────────────
       IdentityUser has no Claims property in this context, so we
       probe the avatars directory directly — same logic as
       Settings.cshtml.cs OnGetAsync, ensuring both pages always
       show the same photo. */
    string? avatarUrl  = null;
    var     userName   = user?.UserName ?? "";
    var     userInitial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "?";

    if (user != null)
    {
        var env        = ViewContext.HttpContext.RequestServices.GetRequiredService<IWebHostEnvironment>();
        var userId     = UserManager.GetUserId(User) ?? "";
        var avatarsDir = System.IO.Path.Combine(env.WebRootPath, "avatars");
        foreach (var ext in new[] { "jpg", "jpeg", "png", "gif", "webp" })
        {
            var candidate = System.IO.Path.Combine(avatarsDir, $"{userId}.{ext}");
            if (System.IO.File.Exists(candidate))
            {
                avatarUrl = $"/avatars/{userId}.{ext}";
                break;
            }
        }
    }

    /* ── Active tab helper ───────────────────────────────────────
       Returns "active" when the current Razor page route ends with
       the given suffix, so the correct tab gets the green underline. */
    string TabClass(string suffix)
    {
        var page = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        return page.EndsWith(suffix, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Statify</title>

    @* Bootstrap — loaded FIRST so app.css and manage.css always win over it *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    @* Google Fonts — same pair as _AppLayout.cshtml *@
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap"
          rel="stylesheet">

    @* Global styles: sidebar, grid, design tokens, hamburger drawer, animations *@
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    @* Manage-page styles: Bootstrap overrides, tabs, content cards, responsive rules *@
    <link rel="stylesheet" href="~/css/manage.css" asp-append-version="true" />
</head>
<body>

    @* ── Hamburger button ─────────────────────────────────────────────────
       Hidden on desktop (> 900px), visible on tablet / mobile.
       sidebar.js toggles .sidebar.open and .sidebar-overlay.active. *@
    <button class="hamburger" id="hamburger-btn"
            aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>

    @* ── Overlay — dims the page content when the mobile drawer is open ── *@
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <div class="app">

        @* ════════════════════════════════════════════════════════
           SIDEBAR
           Identical structure to _AppLayout / _Sidebar.cshtml so
           navigation is consistent across manage and app pages.
           ════════════════════════════════════════════════════════ *@
        <aside class="sidebar" id="sidebar">

            @* Logo — links back to the landing page *@
            <a class="sidebar-logo" asp-page="/Index" asp-area="">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" />
                    </svg>
                </div>
                <span class="logo-text">Statify</span>
            </a>

            @* Main navigation *@
            <nav class="nav" aria-label="Main navigation">

                <div class="nav-label">Menu</div>

                <a class="nav-item" asp-page="/Dashboard" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                    </svg>
                    Dashboard
                </a>

                <a class="nav-item" asp-page="/RecentlyPlayed" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" />
                    </svg>
                    Recently Played
                </a>

                <a class="nav-item" asp-page="/WorldMap" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                    </svg>
                    World Map
                </a>

                <div class="nav-label">Spotify</div>

                @if (!hasSpotify)
                {
                    @* Not connected — green CTA *@
                    <a class="nav-item nav-item--spotify" href="/SpotifyAuth/login">
                        <svg viewBox="0 0 24 24" fill="#1DB954" class="m-spotify-icon" aria-hidden="true">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" />
                        </svg>
                        Connect Spotify
                    </a>
                }
                else
                {
                    @* Connected — read-only status with pulsing dot *@
                    <div class="nav-connected" role="status">
                        <svg viewBox="0 0 24 24" fill="#1DB954" class="m-spotify-icon" aria-hidden="true">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" />
                        </svg>
                        <span class="m-spotify-text">Spotify connected</span>
                        @* Pulse animation defined in app.css @keyframes pulse *@
                        <div class="pulse-dot m-pulse-right"></div>
                    </div>
                }

                <div class="nav-label">Account</div>

                @* Settings is the parent of manage pages — always highlighted here *@
                <a class="nav-item active" asp-page="/Settings" asp-area="">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94zM12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                    </svg>
                    Settings
                </a>

                @* Sign out — POST to Identity logout, redirect to landing page *@
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                    <button type="submit" class="nav-item m-signout-btn">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                        </svg>
                        Sign out
                    </button>
                </form>

            </nav>

            @* ── User card (bottom of sidebar) ──────────────────────────
               Shows the profile photo when avatarUrl is set; otherwise shows
               the first letter of the username as a green circle.
               This is the same photo resolved by Settings.cshtml.cs so the
               two always match. *@
            <a class="sidebar-user" asp-page="/Settings" asp-area="">
                <div class="user-avatar">
                    @if (avatarUrl != null)
                    {
                        <img src="@avatarUrl" alt="Profile photo">
                    }
                    else
                    {
                        @userInitial
                    }
                </div>
                <div>
                    <div class="user-name">@userName</div>
                    <div class="user-sub">Account settings</div>
                </div>
            </a>

        </aside>

        @* ════════════════════════════════════════════════════════
           MAIN CONTENT
           ════════════════════════════════════════════════════════ *@
        <main class="main">

            @* Page title row *@
            <header class="page-header">
                <h1 class="page-title">@ViewData["Title"]</h1>
                <p class="page-sub">Manage your account settings</p>
            </header>

            <div>
                @* ── Sub-page tab bar ─────────────────────────────────────
                   Two-factor tab is intentionally omitted — this feature is
                   not supported in the current version of the app.
                   TabClass() returns "active" when the current page matches. *@
                <nav class="manage-tabs" aria-label="Account settings sections">

                    @* Profile — /Account/Manage/Index *@
                    <a class="manage-tab @TabClass("/Index")"
                       asp-area="Identity" asp-page="/Account/Manage/Index">
                        Profile
                    </a>

                    @* Email — /Account/Manage/Email *@
                    <a class="manage-tab @TabClass("/Email")"
                       asp-area="Identity" asp-page="/Account/Manage/Email">
                        Email
                    </a>

                    @* Password — /Account/Manage/ChangePassword *@
                    <a class="manage-tab @TabClass("/ChangePassword")"
                       asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                        Password
                    </a>

                    @* Linked accounts — /Account/Manage/ExternalLogins *@
                    <a class="manage-tab @TabClass("/ExternalLogins")"
                       asp-area="Identity" asp-page="/Account/Manage/ExternalLogins">
                        Linked accounts
                    </a>

                    @* Personal data — /Account/Manage/PersonalData *@
                    <a class="manage-tab @TabClass("/PersonalData")"
                       asp-area="Identity" asp-page="/Account/Manage/PersonalData">
                        Personal data
                    </a>

                    @* Two-factor tab removed intentionally — not supported *@

                </nav>

                @* Sub-page body injected here by Razor *@
                @RenderBody()
            </div>

        </main>

    </div>

    @* Bootstrap JS — required by Identity Razor pages for form validation *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @* sidebar.js — hamburger open/close for mobile drawer *@
    <script src="~/js/sidebar.js" asp-append-version="true"></script>

    @* Per-page scripts injected by each manage sub-page *@
    @RenderSection("Scripts", required: false)

</body>
</html>
