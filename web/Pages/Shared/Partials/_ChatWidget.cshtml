<button class="chat-fab" id="chat-fab" type="button" aria-label="Ask the chat">
    <svg class="chat-fab__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 6.5C4 5.12 5.12 4 6.5 4h11C18.88 4 20 5.12 20 6.5v7c0 1.38-1.12 2.5-2.5 2.5H11l-4.2 3.15c-.55.41-1.3.02-1.3-.66V16H6.5C5.12 16 4 14.88 4 13.5v-7Z" fill="currentColor"/>
    </svg>
</button>

<div class="chat-panel" id="chat-panel" aria-hidden="true">
    <div class="chat-panel__header">
        <div class="chat-panel__title">Ask Statify</div>
        <button class="chat-panel__close" id="chat-close" type="button" aria-label="Close chat">×</button>
    </div>

    <div class="chat-panel__messages" id="chat-messages">
        <div class="chat-msg chat-msg--bot">
            Hi! Ask about your profile or Spotify connected status.
        </div>
    </div>

    <form class="chat-panel__form" id="chat-form">
        <input class="chat-panel__input" id="chat-input" type="text" placeholder="Ask something..." autocomplete="off" />
        <button class="chat-panel__send" type="submit">Send</button>
    </form>
</div>

