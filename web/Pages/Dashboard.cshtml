@page
@model SpotifyStatisticsWebApp.Pages.DashboardModel
@{
    // Page metadata — sets the browser tab title
    ViewData["Title"] = "Dashboard";
    // Page-specific CSS — injected into <head> by _AppLayout.cshtml
    ViewData["ExtraCss"] = "~/css/dashboard.css";
    // Page-specific JS — injected before </body> by _AppLayout.cshtml
    ViewData["ExtraJs"] = "~/js/dashboard.js";
    // Extra <head> tags — Chart.js is only needed on this page, so we inject it here
    // rather than loading it globally in _AppLayout.cshtml
    ViewData["ExtraHead"] = "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js\"></script>";
    // Pass Spotify connection status down to the sidebar partial (_Sidebar.cshtml)
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;
    // Use the shared app layout (sidebar + head + fonts)
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
    // Human-readable label for the currently selected time range
    var rangeLabel = Model.Range switch
    {
        "7d"  => "Last 7 days",
        "30d" => "Last 30 days",
        "6m"  => "Last 6 months",
        _     => "All time"
    };
}

<main class="main">
    @* ── Top bar: page title + time range filter ── *@
    <header class="topbar">
        <h1 class="page-title">Dashboard</h1>
        @* Time range buttons — clicking reloads the page with ?range=X *@
        <nav class="time-filter" aria-label="Time range">
            <a class="tf-btn @(Model.Range == "7d"  ? "active" : "")" href="?range=7d">7D</a>
            <a class="tf-btn @(Model.Range == "30d" ? "active" : "")" href="?range=30d">30D</a>
            <a class="tf-btn @(Model.Range == "6m"  ? "active" : "")" href="?range=6m">6M</a>
            <a class="tf-btn @(Model.Range is "all" or null ? "active" : "")" href="?range=all">All</a>
        </nav>
    </header>
    @* ── Spotify connection banner — two states ── *@
    @if (!Model.SpotifyConnected)
    {
        @* Shown when Spotify is NOT connected — prompts the user to link their account *@
        <aside class="spotify-banner" id="spotify-banner" aria-label="Connect Spotify">
            <div class="banner-body">
                <div class="spotify-banner-icon">
                    @* Spotify logo SVG icon — inline to avoid extra HTTP request *@
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="#1DB954" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                </div>
                <div class="banner-text">
                    <p class="banner-title">Connect your Spotify account</p>
                    <p class="banner-desc">Link Spotify to start tracking your listening history and unlock your full dashboard.</p>
                </div>
            </div>
            <div class="banner-actions">
                @* Dismiss hides the banner for the current session without a page reload *@
                <button class="dismiss-btn" onclick="document.getElementById('spotify-banner').style.display='none'">Dismiss</button>
                <a href="/SpotifyAuth/login" class="connect-btn">Connect Spotify</a>
            </div>
        </aside>
    }
    else
    {
        @* Shown when Spotify IS connected — subtle status bar with a pulsing dot *@
        <div class="spotify-connected-bar" role="status">
            <div class="pulse-dot"></div>
            <span class="connected-text">Spotify connected — your listening data is being tracked</span>
        </div>
    }
    @* ── Stats grid: 4 summary numbers ── *@
    @* animation-delay staggers each card's fadeUp so they appear one by one *@
    <section class="stats-grid" aria-label="Summary statistics">
        <article class="stat-card">
            <p class="stat-card-label">Tracks played</p>
            <strong class="stat-card-val">@Model.Data.TotalTracks.ToString("N0")</strong>
            <p class="stat-card-sub">@rangeLabel</p>
        </article>
        <article class="stat-card">
            <p class="stat-card-label">Unique artists</p>
            <strong class="stat-card-val">@Model.Data.UniqueArtists</strong>
            <p class="stat-card-sub">@rangeLabel</p>
        </article>
        <article class="stat-card">
            <p class="stat-card-label">Unique albums</p>
            <strong class="stat-card-val">@Model.Data.UniqueAlbums</strong>
            <p class="stat-card-sub">@rangeLabel</p>
        </article>
        <article class="stat-card">
            <p class="stat-card-label">Countries</p>
            <strong class="stat-card-val">@Model.Data.UniqueCountries</strong>
            <p class="stat-card-sub">Artist origins · @rangeLabel</p>
        </article>
    </section>
    @* ── Charts row: activity line chart + time-of-day bars ── *@
    <section class="charts-row" aria-label="Charts">
        @* Line chart — rendered by Chart.js, initialised in dashboard.js → initActivityChart() *@
        <article class="card">
            <header class="card-header">
                <h2 class="card-title">Listening activity</h2>
            </header>
            <canvas id="activityChart" height="100"></canvas>
        </article>
        @* 24 vertical bars (one per hour) — built dynamically in dashboard.js → initTodBars() *@
        <article class="card">
            <header class="card-header">
                <h2 class="card-title">Time of day</h2>
            </header>
            <div class="tod-bars" id="todBars" aria-hidden="true"></div>
            @* Hour labels below the bars *@
            <div class="tod-labels" aria-hidden="true">
                <span class="tod-label">12am</span>
                <span class="tod-label">6am</span>
                <span class="tod-label">12pm</span>
                <span class="tod-label">6pm</span>
                <span class="tod-label">11pm</span>
            </div>
        </article>
    </section>
    @* ── Top Tracks list ── *@
    @* id="section-tracks" is targeted by the scroll-spy in dashboard.js → initScrollSpy() *@
    <section class="card" id="section-tracks" aria-labelledby="tracks-heading">
        <header class="card-header">
            <h2 id="tracks-heading" class="card-title">Top Tracks</h2>
        </header>
        <ol class="top-list">
            @for (int ti = 0; ti < Model.Data.TopTracks.Count; ti++)
            {
                var t = Model.Data.TopTracks[ti];
                var n = ti + 1;
                @* gold / silver / bronze CSS classes colour the rank number *@
                <li class="top-item">
                    <span class="top-rank @(n == 1 ? "gold" : n == 2 ? "silver" : n == 3 ? "bronze" : "")">@n</span>
                    <div class="top-img" aria-hidden="true">🎵</div>
                    <div class="top-info">
                        <span class="top-name">@t.Name</span>
                        <span class="top-sub">@t.Sub</span>
                    </div>
                    <span class="top-count">@t.Count plays</span>
                </li>
            }
        </ol>
    </section>
    @* ── Top Artists list ── *@
    <section class="card" id="section-artists" aria-labelledby="artists-heading">
        <header class="card-header">
            <h2 id="artists-heading" class="card-title">Top Artists</h2>
        </header>
        <ol class="top-list">
            @for (int ai = 0; ai < Model.Data.TopArtists.Count; ai++)
            {
                var a = Model.Data.TopArtists[ai];
                var n = ai + 1;
                @* .circle makes the thumbnail round (artist photo) instead of square (album art) *@
                <li class="top-item">
                    <span class="top-rank @(n == 1 ? "gold" : n == 2 ? "silver" : n == 3 ? "bronze" : "")">@n</span>
                    <div class="top-img circle" aria-hidden="true">👤</div>
                    <div class="top-info">
                        <span class="top-name">@a.Name</span>
                        <span class="top-sub">@a.Sub</span>
                    </div>
                    <span class="top-count">@a.Count plays</span>
                </li>
            }
        </ol>
    </section> 
    @* ── Top Albums list ── *@
    <section class="card" id="section-albums" aria-labelledby="albums-heading">
        <header class="card-header">
            <h2 id="albums-heading" class="card-title">Top Albums</h2>
        </header>
        <ol class="top-list">
            @for (int li = 0; li < Model.Data.TopAlbums.Count; li++)
            {
                var l = Model.Data.TopAlbums[li];
                var n = li + 1;
                <li class="top-item">
                    <span class="top-rank @(n == 1 ? "gold" : n == 2 ? "silver" : n == 3 ? "bronze" : "")">@n</span>
                    <div class="top-img" aria-hidden="true">💿</div>
                    <div class="top-info">
                        <span class="top-name">@l.Name</span>
                        <span class="top-sub">@l.Sub</span>
                    </div>
                    <span class="top-count">@l.Count plays</span>
                </li>
            }
        </ol>
    </section>
</main>
@*
    Scripts section — rendered just before </body> by _AppLayout.cshtml.
    C# model data is serialised to JSON here so dashboard.js can consume it
    as plain JS globals (actLabels, actData, todData) without an extra API call.
*@
@section Scripts {
    <script>
        // Monthly play counts — passed to initActivityChart() in dashboard.js
        const actLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ActivityByMonth.Select(m => m.Month).ToList()));
        const actData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ActivityByMonth.Select(m => m.Count).ToList()));

        // Hourly play counts, array[0..23] — passed to initTodBars() in dashboard.js
        const todData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ListeningByHour));
    </script>
}