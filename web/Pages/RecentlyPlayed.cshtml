@page
@model SpotifyStatisticsWebApp.Pages.RecentlyPlayedModel
@{
    ViewData["Title"] = "Recently Played";
    ViewData["ExtraCss"] = "~/css/recently-played.css";
    ViewData["ExtraJs"] = "~/js/recently-played.js";
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

<main class="main">
    @* ── Page header ── *@
    <header class="page-header">
        <div class="page-header-text">
            <h1 class="page-title">Recently Played</h1>
            <p class="page-sub">Your full listening history, most recent first</p>
        </div>
        <p class="header-meta">
            <strong id="total-count">@Model.TotalCount.ToString("N0")</strong> total plays
        </p>
    </header>

    @* ── Search bar + time range filter ── *@
    <div class="search-bar">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            <input class="search-input" type="search" id="search"
                   placeholder="Search songs, artists, albums…" oninput="filterRows()"
                   aria-label="Search tracks">
        </div>
        <nav class="filter-group" aria-label="Time range filter">
            <button class="filter-btn active" onclick="setFilter(this,'all')">All time</button>
            <button class="filter-btn" onclick="setFilter(this,'7d')">7 days</button>
            <button class="filter-btn" onclick="setFilter(this,'30d')">30 days</button>
            <button class="filter-btn" onclick="setFilter(this,'6m')">6 months</button>
        </nav>
    </div>

    @* ── Track table — rows injected by recently-played.js ── *@
    <section class="track-table" aria-label="Track list">
        <header class="table-head" aria-hidden="true">
            <span>#</span>
            <span>Song</span>
            <span>Artist</span>
            <span>Album</span>
            <span>Country</span>
            <span class="col-played-at">Played at</span>
        </header>
        <ol class="table-body" id="trackList"></ol>
    </section>

    @* ── Infinite scroll sentinel + spinner ── *@
    <div id="scroll-sentinel" style="height:1px"></div>
    <div id="load-spinner" class="spinner-wrap" style="display:none">
        <div class="spinner"></div>
    </div>

    @* ── Empty / error states (hidden until needed) ── *@
    <div id="empty-state" class="empty-state" style="display:none">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
        <p>No tracks found</p>
    </div>
    <div id="error-state" class="empty-state" style="display:none">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 6s4-2 11-2 11 2 11 2"/><path d="M1 18s4-2 11-2 11 2 11 2"/><line x1="1" y1="12" x2="23" y2="12"/></svg>
        <p id="error-msg">Failed to load history</p>
        <button class="filter-btn active" onclick="retryLoad()" style="margin-top:8px">Retry</button>
    </div>
</main>
