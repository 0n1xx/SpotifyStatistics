@page
@model SpotifyStatisticsWebApp.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
    ViewData["ExtraCss"] = "~/css/settings.css";
    ViewData["ExtraJs"] = "~/js/settings.js";
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}
<main class="main">
    <header class="page-header">
        <h1 class="page-title">Settings</h1>
        <p class="page-sub">Manage your account, connections and preferences</p>
    </header>

    @* ── Profile ── *@
    <section class="settings-section" aria-labelledby="profile-heading">
        <h2 id="profile-heading" class="section-title">Profile</h2>
        <article class="setting-card">
            <div class="avatar-section">
                <figure class="avatar-large" aria-label="Profile photo">
                    @if (Model.AvatarDataUrl != null)
                    {
                        <img src="@Model.AvatarDataUrl" alt="Profile photo" id="avatar-preview">
                    }
                    else
                    {
                        <span id="avatar-initials">@User.Identity?.Name?.Substring(0, 1).ToUpper()</span>
                        <img id="avatar-preview" src="" alt="Profile photo" class="avatar-preview-hidden">
                    }
                </figure>
                <div class="avatar-info">
                    @* Show DisplayName if set, otherwise fall back to email *@
                    <p class="avatar-name">@(Model.DisplayName ?? User.Identity?.Name)</p>
                    <p class="avatar-email">@User.Identity?.Name</p>
                    <div class="avatar-actions">
                        <button class="btn btn-outline" id="upload-avatar-btn"
                                onclick="document.getElementById('avatar-input').click()">
                            Upload photo
                        </button>
                        <span id="avatar-upload-status" class="upload-status"></span>
                        <input id="avatar-input" type="file" accept="image/*"
                               class="file-input-hidden" aria-label="Upload profile photo">
                        @Html.AntiForgeryToken()
                    </div>
                </div>
            </div>
        </article>
    </section>

    @* ── Account ── *@
    <section class="settings-section" aria-labelledby="account-heading">
        <h2 id="account-heading" class="section-title">Account</h2>
        <article class="setting-card">

            @* Display name — shown in sidebar and profile header, falls back to email *@
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">Display name</p>
                    <p class="setting-desc">Shown in your profile and sidebar. Max 50 characters.</p>
                </div>
                <div class="setting-actions">
                    <input class="input-field" type="text" id="username-input"
                           value="@Model.DisplayName" placeholder="Your name"
                           maxlength="50" aria-label="Display name">
                    <button class="btn btn-green" onclick="saveUsername()">Save</button>
                </div>
            </div>

            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">Email address</p>
                    <p class="setting-desc">Your login email and where we send notifications</p>
                </div>
                <div class="setting-actions">
                    <input class="input-field" type="email" id="email-input"
                           value="@User.Identity?.Name" aria-label="Email address">
                    <button class="btn btn-green" onclick="saveEmail()">Save</button>
                </div>
            </div>
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">Phone number</p>
                    <p class="setting-desc">Optional — used for account recovery</p>
                </div>
                <div class="setting-actions">
                    <input class="input-field" type="tel" id="phone-input"
                           value="@Model.PhoneNumber" placeholder="+1 555 000 0000"
                           aria-label="Phone number">
                    <button class="btn btn-green" onclick="savePhone()">Save</button>
                </div>
            </div>
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">Password</p>
                    <p class="setting-desc">Change your account password</p>
                </div>
                <a class="btn btn-outline" asp-area="Identity"
                   asp-page="/Account/Manage/ChangePassword">Change password</a>
            </div>
        </article>
    </section>

    @* ── Connected accounts ── *@
    <section class="settings-section" aria-labelledby="connections-heading">
        <h2 id="connections-heading" class="section-title">Connected accounts</h2>
        <article class="setting-card">
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label setting-label--icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="#1DB954" aria-hidden="true">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z"/>
                        </svg>
                        Spotify
                    </p>
                    <p class="setting-desc">Access your listening history and stats</p>
                </div>
                <div class="setting-actions">
                    @if (Model.SpotifyConnected)
                    {
                        <span class="connected-badge yes">
                            <div class="pulse-dot"></div>
                            Connected
                        </span>
                        <button class="btn btn-outline"
                                onclick="if(confirm('Disconnect Spotify?')) window.location='/SpotifyAuth/disconnect'">
                            Disconnect
                        </button>
                    }
                    else
                    {
                        <span class="connected-badge no">Not connected</span>
                        <a class="btn btn-green" href="/SpotifyAuth/login">Connect</a>
                    }
                </div>
            </div>
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">Google</p>
                    <p class="setting-desc">Sign in with your Google account</p>
                </div>
                <div class="setting-actions">
                    @if (Model.GoogleConnected)
                    {
                        <span class="connected-badge yes">Connected</span>
                    }
                    else
                    {
                        <span class="connected-badge no">Not connected</span>
                        <form method="post" asp-page-handler="LinkLogin" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" name="provider" value="Google" class="btn btn-outline">Connect</button>
                        </form>
                    }
                </div>
            </div>
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">GitHub</p>
                    <p class="setting-desc">Sign in with your GitHub account</p>
                </div>
                <div class="setting-actions">
                    @if (Model.GitHubConnected)
                    {
                        <span class="connected-badge yes">Connected</span>
                    }
                    else
                    {
                        <span class="connected-badge no">Not connected</span>
                        <form method="post" asp-page-handler="LinkLogin" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" name="provider" value="GitHub" class="btn btn-outline">Connect</button>
                        </form>
                    }
                </div>
            </div>
        </article>
    </section>

    @* ── Danger zone ── *@
    <section class="settings-section" aria-labelledby="danger-heading">
        <h2 id="danger-heading" class="section-title">Danger zone</h2>
        <article class="danger-zone">
            <header class="danger-header">
                <p class="danger-title">Irreversible actions</p>
            </header>
            <div class="setting-row">
                <div class="setting-info">
                    <p class="setting-label">Delete account</p>
                    <p class="setting-desc">Permanently delete your account and all data. This cannot be undone.</p>
                </div>
                <button class="btn btn-red" onclick="confirmDelete()">Delete account</button>
            </div>
        </article>
    </section>

    @* ── Delete confirmation modal — uses native <dialog> element ── *@
    <dialog id="delete-modal" class="delete-modal" aria-labelledby="modal-title">
        <article class="delete-modal__card">
            <h2 id="modal-title" class="delete-modal__title">Delete your account?</h2>
            <p class="delete-modal__desc">
                This will permanently delete your account and all your listening history.
                There is no way to recover this data.
            </p>
            <footer class="delete-modal__actions">
                <button class="btn btn-outline"
                        onclick="document.getElementById('delete-modal').close()">Cancel</button>
                <form method="post" asp-page-handler="DeleteAccount">
                    <button type="submit" class="btn btn-danger">Yes, delete everything</button>
                </form>
            </footer>
        </article>
    </dialog>
</main>
