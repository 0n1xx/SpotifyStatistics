@page
@model SpotifyStatisticsWebApp.Pages.WorldMapModel
@{
    // Page metadata
    ViewData["Title"] = "World Map";
    // Page-specific CSS
    ViewData["ExtraCss"] = "~/css/worldmap.css";
    // Page-specific JS — D3 map logic lives in worldmap.js
    ViewData["ExtraJs"] = "~/js/worldmap.js";
    // D3.js (SVG map rendering) and TopoJSON (country geometry) are only needed on this page
    ViewData["ExtraHead"] = "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js\"></script>"
                          + "<script src=\"https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js\"></script>";
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}
<main class="main">
    @* ── Page header: title + summary counts ── *@
    <header class="page-header">
        <div class="page-header-text">
            <h1 class="page-title">World Map</h1>
            <p class="page-sub">Artist origins across your listening history</p>
        </div>
        <p class="map-meta">
            <strong>@Model.CountryCounts.Count</strong> countries
            &middot;
            <strong>@Model.CountryCounts.Sum(c => c.Count).ToString("N0")</strong> plays
        </p>
    </header>
    @* ── Map area — SVG populated by D3 in worldmap.js → initMap() ── *@
    <section class="map-area" aria-label="World map of listening history">
        @* D3 renders country paths into this SVG element *@
        <svg id="world-map-svg" aria-hidden="true"></svg>
        @* ── Top countries panel (right-side overlay) ── *@
        <aside class="country-panel" aria-label="Top countries">
            <h2 class="country-panel-header">Top Countries</h2>
            <ol class="country-list">
                @* Bar width is proportional to the top country's play count *@
                @{ int maxPlays = Model.CountryCounts.FirstOrDefault()?.Count ?? 1; }
                @foreach (var c in Model.CountryCounts.Take(15))
                {
                    double pct = (double)c.Count / maxPlays * 100;
                    <li class="country-row">
                        <span class="country-name">@c.Country</span>
                        <div class="country-bar-wrap" aria-hidden="true">
                            <div class="country-bar" style="width:@pct.ToString("F0")%" data-pct="@pct.ToString("F0")"></div>
                        </div>
                        <span class="country-plays">@c.Count</span>
                    </li>
                }
            </ol>
        </aside>
        @* ── Hover tooltip — shown/hidden by D3 mousemove in worldmap.js ── *@
        <div id="map-tooltip" role="tooltip" aria-live="polite">
            <div class="tt-name"></div>
            <div class="tt-plays"></div>
        </div>
        @* ── Legend: colour scale explanation ── *@
        <figure class="map-legend" aria-label="Colour legend">
            <div class="legend-gradient" aria-hidden="true"></div>
            <figcaption>Listening intensity</figcaption>
        </figure>
        @* ── Zoom controls — wired up in worldmap.js ── *@
        <nav class="zoom-controls" aria-label="Map zoom">
            <button class="zoom-btn" id="zoom-in" aria-label="Zoom in">+</button>
            <button class="zoom-btn" id="zoom-out" aria-label="Zoom out">&minus;</button>
            @* Home button resets to the default zoom level and pan position *@
            <button class="zoom-btn zoom-btn--reset" id="zoom-reset" aria-label="Reset zoom">&#8962;</button>
        </nav>
    </section>
</main>
@*
    Scripts section — countryData is serialised from C# to a JS object so
    worldmap.js can colour each country without an extra API call.
    Format: { "US": 142, "GB": 87, ... }
*@
@section Scripts {
    <script>
        const countryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.CountryCounts.ToDictionary(c => c.Country ?? "unknown", c => c.Count)
        ));
    </script>
}