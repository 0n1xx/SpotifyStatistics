@page
@model SpotifyStatisticsWebApp.Pages.SettingsModel
@{
    ViewData["Title"] = "Settings";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings — Statify</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --green: #1DB954;
            --green-dim: #17a349;
            --green-glow: rgba(29,185,84,0.15);
            --black: #080808;
            --card: #111111;
            --card2: #161616;
            --border: rgba(255,255,255,0.07);
            --text: #f0f0f0;
            --muted: #555;
            --muted2: #888;
            --sidebar: 240px;
            --red: #e74c3c;
            --red-glow: rgba(231,76,60,0.15);
        }

        html, body {
            height: 100%;
            background: var(--black);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            overflow: hidden;
        }

        .app {
            display: grid;
            grid-template-columns: var(--sidebar) 1fr;
            height: 100vh;
        }

        .sidebar {
            background: #0c0c0c;
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 28px 0;
            overflow-y: auto;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 24px 28px;
            border-bottom: 1px solid var(--border);
            text-decoration: none;
        }

        .logo-icon {
            width: 34px;
            height: 34px;
            background: var(--green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .logo-icon svg {
                width: 18px;
                height: 18px;
                fill: #000;
            }

        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--text);
        }

        .nav {
            padding: 20px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0 12px;
            margin-bottom: 8px;
            margin-top: 20px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 14px;
            color: var(--muted2);
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            margin-bottom: 2px;
        }

            .nav-item svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
                opacity: 0.6;
            }

            .nav-item:hover {
                background: var(--card);
                color: var(--text);
            }

                .nav-item:hover svg {
                    opacity: 1;
                }

            .nav-item.active {
                background: var(--green-glow);
                color: var(--green);
                font-weight: 500;
            }

                .nav-item.active svg {
                    opacity: 1;
                }

        .sidebar-user {
            margin: 0 12px;
            padding: 12px;
            background: var(--card);
            border-radius: 10px;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            text-decoration: none;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--green);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: #000;
            flex-shrink: 0;
            overflow: hidden;
        }

            .user-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
        }

        .user-sub {
            font-size: 11px;
            color: var(--muted2);
        }

        .main {
            overflow-y: auto;
            padding: 40px 48px;
            display: flex;
            flex-direction: column;
            gap: 32px;
        }

            .main::-webkit-scrollbar {
                width: 4px;
            }

            .main::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 2px;
            }

        .page-header {
            display: flex;
            flex-direction: column;
            gap: 6px;
            padding-bottom: 28px;
            border-bottom: 1px solid var(--border);
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .page-sub {
            font-size: 14px;
            color: var(--muted2);
        }

        .settings-section {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .section-title {
            font-family: 'Syne', sans-serif;
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: 0.02em;
        }

        .setting-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            animation: fadeUp 0.4s ease both;
        }

        .setting-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 24px;
            gap: 20px;
            border-bottom: 1px solid var(--border);
        }

            .setting-row:last-child {
                border-bottom: none;
            }

        .setting-info {
            flex: 1;
            min-width: 0;
        }

        .setting-label {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 4px;
        }

        .setting-desc {
            font-size: 12px;
            color: var(--muted2);
            line-height: 1.5;
        }

        .setting-value {
            font-size: 13px;
            color: var(--muted2);
            flex-shrink: 0;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .btn {
            padding: 9px 18px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            transition: all 0.15s;
            border: none;
            flex-shrink: 0;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text);
        }

            .btn-outline:hover {
                border-color: rgba(255,255,255,0.2);
                background: var(--card2);
            }

        .btn-green {
            background: var(--green);
            color: #000;
            font-weight: 600;
        }

            .btn-green:hover {
                background: var(--green-dim);
            }

        .btn-red {
            background: transparent;
            border: 1px solid rgba(231,76,60,0.3);
            color: var(--red);
        }

            .btn-red:hover {
                background: var(--red-glow);
                border-color: var(--red);
            }

        .avatar-section {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 20px 24px;
        }

        .avatar-large {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: var(--green);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 700;
            color: #000;
            flex-shrink: 0;
            overflow: hidden;
            border: 2px solid var(--border);
        }

            .avatar-large img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .avatar-info {
            flex: 1;
        }

        .avatar-name {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .avatar-email {
            font-size: 13px;
            color: var(--muted2);
        }

        .avatar-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
        }

        .input-field {
            background: #1a1a1a;
            border: 1px solid var(--border);
            border-radius: 9px;
            padding: 10px 14px;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            color: var(--text);
            outline: none;
            transition: border-color 0.2s;
            width: 100%;
            max-width: 320px;
        }

            .input-field:focus {
                border-color: var(--green);
            }

            .input-field::placeholder {
                color: #444;
            }

        .connected-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 10px;
            border-radius: 99px;
            font-size: 11px;
            font-weight: 500;
        }

            .connected-badge.yes {
                background: rgba(29,185,84,0.1);
                color: var(--green);
                border: 1px solid rgba(29,185,84,0.2);
            }

            .connected-badge.no {
                background: rgba(255,255,255,0.04);
                color: var(--muted2);
                border: 1px solid var(--border);
            }

            .connected-badge svg {
                width: 12px;
                height: 12px;
            }

        .danger-zone {
            background: rgba(231,76,60,0.04);
            border: 1px solid rgba(231,76,60,0.15);
            border-radius: 14px;
            overflow: hidden;
        }

        .danger-header {
            padding: 16px 24px;
            border-bottom: 1px solid rgba(231,76,60,0.15);
        }

        .danger-title {
            font-size: 13px;
            font-weight: 500;
            color: var(--red);
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .success-msg {
            display: none;
            font-size: 12px;
            color: var(--green);
            margin-top: 6px;
        }

        .pulse-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--green);
            animation: pulse 2s ease-in-out infinite;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.4;
            }
        }

        .nav-connected {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 14px;
            color: var(--green);
            margin-bottom: 2px;
        }

            .nav-connected svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
            }
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <a class="sidebar-logo" asp-page="/Index">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                </div>
                <span class="logo-text">Statify</span>
            </a>
            <nav class="nav">
                <div class="nav-label">Menu</div>
                <a class="nav-item" asp-page="/Dashboard">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" /></svg>
                    Dashboard
                </a>
                <a class="nav-item" asp-page="/RecentlyPlayed">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" /></svg>
                    Recently Played
                </a>
                <a class="nav-item" asp-page="/TopTracks">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z" /></svg>
                    Top Tracks
                </a>
                <a class="nav-item" asp-page="/TopArtists">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>
                    Top Artists
                </a>
                <a class="nav-item" asp-page="/TopAlbums">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" /></svg>
                    Top Albums
                </a>
                <a class="nav-item" asp-page="/WorldMap">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                    World Map
                </a>
                <div class="nav-label">Spotify</div>
                @if (!Model.SpotifyConnected)
                {
                    <a class="nav-item" href="/SpotifyAuth/login" style="color:#1DB954;border:1px solid rgba(29,185,84,0.2);background:rgba(29,185,84,0.05)">
                        <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        Connect Spotify
                    </a>
                }
                else
                {
                    <div class="nav-connected">
                        <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        <span style="font-size:13px">Spotify connected</span>
                        <div class="pulse-dot" style="margin-left:auto"></div>
                    </div>
                }
                <div class="nav-label">Account</div>
                <a class="nav-item active" asp-page="/Settings">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" /></svg>
                    Settings
                </a>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                    <button type="submit" class="nav-item" style="width:100%;border:none;background:none;text-align:left;cursor:pointer">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" /></svg>
                        Sign out
                    </button>
                </form>
            </nav>
            <a class="sidebar-user" asp-page="/Settings">
                <div class="user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                <div>
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-sub">@(Model.SpotifyConnected ? "Spotify connected" : "Spotify not connected")</div>
                </div>
            </a>
        </aside>

        <main class="main">
            <div class="page-header">
                <h1 class="page-title">Settings</h1>
                <p class="page-sub">Manage your account, connections and preferences</p>
            </div>

            <!-- Profile -->
            <div class="settings-section" style="animation-delay:0s">
                <div class="section-title">Profile</div>
                <div class="setting-card">
                    <div class="avatar-section">
                        <div class="avatar-large">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                        <div>
                            <div class="avatar-name">@User.Identity?.Name</div>
                            <div class="avatar-email">@User.Identity?.Name</div>
                            <div class="avatar-actions">
                                <button class="btn btn-outline" onclick="document.getElementById('avatar-input').click()">Upload photo</button>
                                <input id="avatar-input" type="file" accept="image/*" style="display:none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Email -->
            <div class="settings-section" style="animation-delay:0.05s">
                <div class="section-title">Account</div>
                <div class="setting-card">
                    <div class="setting-row">
                        <div class="setting-info">
                            <div class="setting-label">Email address</div>
                            <div class="setting-desc">Your login email and where we send notifications</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:10px">
                            <input class="input-field" type="email" id="email-input" value="@User.Identity?.Name" style="max-width:220px">
                            <button class="btn btn-green" onclick="saveEmail()">Save</button>
                        </div>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info">
                            <div class="setting-label">Password</div>
                            <div class="setting-desc">Change your account password</div>
                        </div>
                        <a class="btn btn-outline" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Change password</a>
                    </div>
                </div>
            </div>

            <!-- Connected accounts -->
            <div class="settings-section" style="animation-delay:0.1s">
                <div class="section-title">Connected accounts</div>
                <div class="setting-card">
                    <div class="setting-row">
                        <div class="setting-info">
                            <div class="setting-label" style="display:flex;align-items:center;gap:8px">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                                Spotify
                            </div>
                            <div class="setting-desc">Access your listening history and stats</div>
                        </div>
                        <div style="display:flex;align-items:center;gap:10px">
                            @if (Model.SpotifyConnected)
                            {
                                <span class="connected-badge yes">
                                    <div class="pulse-dot"></div>
                                    Connected
                                </span>
                                <button class="btn btn-outline" onclick="if(confirm('Disconnect Spotify?')) window.location='/SpotifyAuth/disconnect'">Disconnect</button>
                            }
                            else
                            {
                                <span class="connected-badge no">Not connected</span>
                                <a class="btn btn-green" href="/SpotifyAuth/login">Connect</a>
                            }
                        </div>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info">
                            <div class="setting-label" style="display:flex;align-items:center;gap:8px">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" /><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" /><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" /><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" /></svg>
                                Google
                            </div>
                            <div class="setting-desc">Sign in with your Google account</div>
                        </div>
                        <span class="connected-badge @(Model.GoogleConnected ? "yes" : "no")">
                            @(Model.GoogleConnected ? "Connected" : "Not connected")
                        </span>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info">
                            <div class="setting-label" style="display:flex;align-items:center;gap:8px">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" /></svg>
                                GitHub
                            </div>
                            <div class="setting-desc">Sign in with your GitHub account</div>
                        </div>
                        <span class="connected-badge @(Model.GitHubConnected ? "yes" : "no")">
                            @(Model.GitHubConnected ? "Connected" : "Not connected")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Danger zone -->
            <div class="settings-section" style="animation-delay:0.15s">
                <div class="section-title">Danger zone</div>
                <div class="danger-zone">
                    <div class="danger-header">
                        <div class="danger-title">Irreversible actions</div>
                    </div>
                    <div class="setting-row">
                        <div class="setting-info">
                            <div class="setting-label">Delete account</div>
                            <div class="setting-desc">Permanently delete your account and all associated data. This cannot be undone.</div>
                        </div>
                        <button class="btn btn-red" onclick="confirmDelete()">Delete account</button>
                    </div>
                </div>
            </div>

            <!-- Delete confirm modal -->
            <div id="delete-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:100;display:none;align-items:center;justify-content:center">
                <div style="background:#111;border:1px solid rgba(231,76,60,0.3);border-radius:16px;padding:32px;max-width:400px;width:90%;text-align:center">
                    <div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:12px">Delete your account?</div>
                    <div style="font-size:14px;color:#888;line-height:1.6;margin-bottom:24px">This will permanently delete your account and all your listening history. There is no way to recover this data.</div>
                    <div style="display:flex;gap:10px;justify-content:center">
                        <button class="btn btn-outline" onclick="document.getElementById('delete-modal').style.display='none'">Cancel</button>
                        <form method="post" asp-page-handler="DeleteAccount" style="margin:0">
                            <button type="submit" class="btn" style="background:var(--red);color:#fff;font-weight:600">Yes, delete everything</button>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        function confirmDelete() {
            document.getElementById('delete-modal').style.display = 'flex';
        }
        function saveEmail() {
            const email = document.getElementById('email-input').value;
            alert('Email update coming soon: ' + email);
        }
    </script>
</body>
</html>
