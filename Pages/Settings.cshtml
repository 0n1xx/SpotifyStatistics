@page
@model SpotifyStatisticsWebApp.Pages.SettingsModel
@{
    // Page metadata
    ViewData["Title"] = "Settings";
    // Page-specific CSS — injected into <head> by _AppLayout.cshtml
    ViewData["ExtraCss"] = "~/css/settings.css";
    // Page-specific JS — injected before </body> by _AppLayout.cshtml
    ViewData["ExtraJs"] = "~/js/settings.js";
    // Pass Spotify connection status to the sidebar partial
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

<main class="main">
    @* ── Page header ── *@
    <div class="page-header">
        <h1 class="page-title">Settings</h1>
        <p class="page-sub">Manage your account, connections and preferences</p>
    </div>
    @* ── Section: Profile ── *@
    <div class="settings-section" style="animation-delay:0s">
        <div class="section-title">Profile</div>
        <div class="setting-card">
            <div class="avatar-section">
                @* First letter of username as fallback avatar *@
                <div class="avatar-large">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                <div>
                    <div class="avatar-name">@User.Identity?.Name</div>
                    <div class="avatar-email">@User.Identity?.Name</div>
                    <div class="avatar-actions">
                        @* Hidden file input — triggered by the button click *@
                        <button class="btn btn-outline" onclick="document.getElementById('avatar-input').click()">Upload photo</button>
                        <input id="avatar-input" type="file" accept="image/*" style="display:none">
                    </div>
                </div>
            </div>
        </div>
    </div>
    @* ── Section: Account ── *@
    <div class="settings-section" style="animation-delay:0.05s">
        <div class="section-title">Account</div>
        <div class="setting-card">
            <div class="setting-row">
                <div class="setting-info">
                    <div class="setting-label">Email address</div>
                    <div class="setting-desc">Your login email and where we send notifications</div>
                </div>
                <div style="display:flex;align-items:center;gap:10px">
                    <input class="input-field" type="email" id="email-input"
                           value="@User.Identity?.Name" style="max-width:220px">
                    @* saveEmail() is defined in settings.js *@
                    <button class="btn btn-green" onclick="saveEmail()">Save</button>
                </div>
            </div>
            <div class="setting-row">
                <div class="setting-info">
                    <div class="setting-label">Password</div>
                    <div class="setting-desc">Change your account password</div>
                </div>
                @* Links to the ASP.NET Identity built-in password change page *@
                <a class="btn btn-outline" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Change password</a>
            </div>
        </div>
    </div>
    @* ── Section: Connected accounts ── *@
    <div class="settings-section" style="animation-delay:0.1s">
        <div class="section-title">Connected accounts</div>
        <div class="setting-card">

            @* Spotify row — shows Connect or Disconnect depending on Model.SpotifyConnected *@
            <div class="setting-row">
                <div class="setting-info">
                    <div class="setting-label" style="display:flex;align-items:center;gap:8px">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        Spotify
                    </div>
                    <div class="setting-desc">Access your listening history and stats</div>
                </div>
                <div style="display:flex;align-items:center;gap:10px">
                    @if (Model.SpotifyConnected)
                    {
                        <span class="connected-badge yes">
                            <div class="pulse-dot"></div>
                            Connected
                        </span>
                        <button class="btn btn-outline"
                                onclick="if(confirm('Disconnect Spotify?')) window.location='/SpotifyAuth/disconnect'">
                            Disconnect
                        </button>
                    }
                    else
                    {
                        <span class="connected-badge no">Not connected</span>
                        <a class="btn btn-green" href="/SpotifyAuth/login">Connect</a>
                    }
                </div>
            </div>
            @* Google row — read-only status badge, no connect/disconnect action yet *@
            <div class="setting-row">
                <div class="setting-info">
                    <div class="setting-label">Google</div>
                    <div class="setting-desc">Sign in with your Google account</div>
                </div>
                <span class="connected-badge @(Model.GoogleConnected ? "yes" : "no")">
                    @(Model.GoogleConnected ? "Connected" : "Not connected")
                </span>
            </div>
            @* GitHub row — read-only status badge *@
            <div class="setting-row">
                <div class="setting-info">
                    <div class="setting-label">GitHub</div>
                    <div class="setting-desc">Sign in with your GitHub account</div>
                </div>
                <span class="connected-badge @(Model.GitHubConnected ? "yes" : "no")">
                    @(Model.GitHubConnected ? "Connected" : "Not connected")
                </span>
            </div>
        </div>
    </div>
    @* ── Section: Danger zone ── *@
    @* Styled red to make it visually distinct from the other sections *@
    <div class="settings-section" style="animation-delay:0.15s">
        <div class="section-title">Danger zone</div>
        <div class="danger-zone">
            <div class="danger-header">
                <div class="danger-title">Irreversible actions</div>
            </div>
            <div class="setting-row">
                <div class="setting-info">
                    <div class="setting-label">Delete account</div>
                    <div class="setting-desc">Permanently delete your account and all data. This cannot be undone.</div>
                </div>
                @* Opens the confirmation modal defined below — confirmDelete() is in settings.js *@
                <button class="btn btn-red" onclick="confirmDelete()">Delete account</button>
            </div>
        </div>
    </div>
    @* ── Delete confirmation modal ── *@
    @* Hidden by default; shown by confirmDelete() in settings.js *@
    <div id="delete-modal"
         style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:100;align-items:center;justify-content:center">
        <div style="background:#111;border:1px solid rgba(231,76,60,0.3);border-radius:16px;padding:32px;max-width:400px;width:90%;text-align:center">
            <div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:12px">Delete your account?</div>
            <div style="font-size:14px;color:#888;line-height:1.6;margin-bottom:24px">
                This will permanently delete your account and all your listening history.
                There is no way to recover this data.
            </div>
            <div style="display:flex;gap:10px;justify-content:center">
                <button class="btn btn-outline"
                        onclick="document.getElementById('delete-modal').style.display='none'">Cancel</button>
                @* POST to DeleteAccount handler in Settings.cshtml.cs *@
                <form method="post" asp-page-handler="DeleteAccount" style="margin:0">
                    <button type="submit" class="btn"
                            style="background:var(--red);color:#fff;font-weight:600">Yes, delete everything</button>
                </form>
            </div>
        </div>
    </div>
</main>
