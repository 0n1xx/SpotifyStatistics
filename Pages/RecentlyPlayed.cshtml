@page
@model SpotifyStatisticsWebApp.Pages.RecentlyPlayedModel
@{
    // Page metadata
    ViewData["Title"] = "Recently Played";

    // Page-specific CSS — injected into <head> by _AppLayout.cshtml
    ViewData["ExtraCss"] = "~/css/recently-played.css";

    // Page-specific JS — injected before </body> by _AppLayout.cshtml
    ViewData["ExtraJs"] = "~/js/recently-played.js";

    // Pass Spotify connection status to the sidebar partial
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;

    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}
<main class="main">
    @* ── Page header: title + total play count ── *@
    <div class="page-header">
        <div>
            <h1 class="page-title">Recently Played</h1>
            <p class="page-sub">Your full listening history, most recent first</p>
        </div>
        <div class="header-meta">
            <strong>@Model.TotalCount.ToString("N0")</strong> total plays
        </div>
    </div>
    @* ── Search bar + time range filter buttons ── *@
    <div class="search-bar">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            @* oninput calls filterRows() in recently-played.js — filters without page reload *@
            <input class="search-input" type="text" id="search"
                   placeholder="Search songs, artists, albums…" oninput="filterRows()">
        </div>
        @* Time filter buttons — call setFilter() in recently-played.js *@
        <div class="filter-group">
            <button class="filter-btn active" onclick="setFilter(this,'all')">All time</button>
            <button class="filter-btn" onclick="setFilter(this,'7d')">7 days</button>
            <button class="filter-btn" onclick="setFilter(this,'30d')">30 days</button>
            <button class="filter-btn" onclick="setFilter(this,'6m')">6 months</button>
        </div>
    </div>
    @* ── Track table ── *@
    <div class="track-table">
        @* Column headers *@
        <div class="table-head">
            <span>#</span>
            <span>Song</span>
            <span>Artist</span>
            <span>Album</span>
            <span>Country</span>
            <span style="text-align:right">Played at</span>
        </div>
        <div class="table-body" id="trackList">
            @* Starting index accounts for pagination offset *@
            @{ int idx = (Model.Page - 1) * Model.PageSize + 1; }

            @foreach (var t in Model.Tracks)
            {
                @* data-* attributes are read by filterRows() and setFilter() in recently-played.js *@
                <div class="track-row"
                     data-song="@t.Song.ToLower()"
                     data-artist="@t.Artist.ToLower()"
                     data-album="@t.Album.ToLower()"
                     data-played="@t.PlayedAt.ToString("o")"
                     style="animation-delay:@(((idx - 1) % Model.PageSize) * 0.012)s">
                    <span class="track-num">@idx</span>
                    <div class="track-song">
                        <div class="track-icon">🎵</div>
                        <span class="track-name" title="@t.Song">@t.Song</span>
                    </div>
                    <span class="track-artist" title="@t.Artist">@t.Artist</span>
                    <span class="track-album" title="@t.Album">@t.Album</span>
                    @* Show em-dash if country is missing or unknown *@
                    <span class="track-country">@(string.IsNullOrEmpty(t.Country) || t.Country == "unknown" ? "—" : t.Country)</span>
                    <span class="track-time">@t.PlayedAt.ToString("MMM d, HH:mm")</span>
                </div>
                idx++;
            }
        </div>
    </div>
    @* ── Pagination controls ── *@
    <div class="pagination">
        <div class="page-info">
            Page <strong>@Model.Page</strong> of <strong>@Model.TotalPages</strong>
            &nbsp;·&nbsp; showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount))
            of <strong>@Model.TotalCount.ToString("N0")</strong>
        </div>
        <div class="page-btns">
            @* First / Prev — disabled on page 1 *@
            @if (Model.Page > 1)
            {
                <a class="page-btn" asp-page="/RecentlyPlayed" asp-route-page="1">«</a>
                <a class="page-btn" asp-page="/RecentlyPlayed" asp-route-page="@(Model.Page - 1)">‹ Prev</a>
            }
            else
            {
                <span class="page-btn disabled">«</span>
                <span class="page-btn disabled">‹ Prev</span>
            }
            @* Numbered page buttons — show a window of ±2 pages around current *@
            @{ int startPage = Math.Max(1, Model.Page - 2); int endPage = Math.Min(Model.TotalPages, Model.Page + 2); }
            @for (int p = startPage; p <= endPage; p++)
            {
                if (p == Model.Page) { <span class="page-btn active">@p</span> }
                else { <a class="page-btn" asp-page="/RecentlyPlayed" asp-route-page="@p">@p</a> }
            }

            @* Next / Last — disabled on last page *@
            @if (Model.Page < Model.TotalPages)
            {
                <a class="page-btn" asp-page="/RecentlyPlayed" asp-route-page="@(Model.Page + 1)">Next ›</a>
                <a class="page-btn" asp-page="/RecentlyPlayed" asp-route-page="@Model.TotalPages">»</a>
            }
            else
            {
                <span class="page-btn disabled">Next ›</span>
                <span class="page-btn disabled">»</span>
            }
        </div>
    </div>
</main>