@page
@model SpotifyStatisticsWebApp.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — Statify</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --green: #1DB954;
            --green-dim: #17a349;
            --green-glow: rgba(29,185,84,0.15);
            --black: #080808;
            --card: #111111;
            --card2: #161616;
            --border: rgba(255,255,255,0.07);
            --text: #f0f0f0;
            --muted: #555;
            --muted2: #888;
            --sidebar: 240px;
        }

        html, body {
            height: 100%;
            background: var(--black);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            overflow: hidden;
        }

        .app {
            display: grid;
            grid-template-columns: var(--sidebar) 1fr;
            height: 100vh;
        }

        .sidebar {
            background: #0c0c0c;
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 28px 0;
            overflow-y: auto;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 24px 28px;
            border-bottom: 1px solid var(--border);
            text-decoration: none;
            color: var(--text);
        }

        .logo-icon {
            width: 34px;
            height: 34px;
            background: var(--green);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .logo-icon svg {
                width: 18px;
                height: 18px;
                fill: #000;
            }

        .logo-text {
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .nav {
            padding: 20px 12px;
            flex: 1;
        }

        .nav-label {
            font-size: 10px;
            font-weight: 500;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--muted);
            padding: 0 12px;
            margin-bottom: 8px;
            margin-top: 20px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 14px;
            color: var(--muted2);
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
            margin-bottom: 2px;
        }

            .nav-item svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
                opacity: 0.6;
            }

            .nav-item:hover {
                background: var(--card);
                color: var(--text);
            }

                .nav-item:hover svg {
                    opacity: 1;
                }

            .nav-item.active {
                background: var(--green-glow);
                color: var(--green);
                font-weight: 500;
            }

                .nav-item.active svg {
                    opacity: 1;
                }

        .sidebar-user {
            margin: 0 12px;
            padding: 12px;
            background: var(--card);
            border-radius: 10px;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            cursor: pointer;
            transition: border-color 0.15s;
        }

            .sidebar-user:hover {
                border-color: rgba(255,255,255,0.15);
            }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--green);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: #000;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
        }

        .user-sub {
            font-size: 11px;
            color: var(--muted2);
        }

        .main {
            overflow-y: auto;
            padding: 32px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .time-filter {
            display: flex;
            background: var(--card);
            border-radius: 8px;
            padding: 3px;
            border: 1px solid var(--border);
        }

        .tf-btn {
            padding: 6px 14px;
            font-size: 12px;
            font-weight: 500;
            color: var(--muted2);
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.15s;
            border: none;
            background: none;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
        }

            .tf-btn:hover {
                color: var(--text);
            }

            .tf-btn.active {
                background: var(--green);
                color: #000;
            }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
        }

        .stat-card {
            background: var(--card);
            border-radius: 14px;
            border: 1px solid var(--border);
            padding: 20px;
            animation: fadeUp 0.4s ease both;
        }

        .stat-card-label {
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted2);
            margin-bottom: 10px;
        }

        .stat-card-val {
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-card-sub {
            font-size: 12px;
            color: var(--muted2);
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 16px;
        }

        .card {
            background: var(--card);
            border-radius: 14px;
            border: 1px solid var(--border);
            padding: 22px;
            animation: fadeUp 0.4s ease both;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .card-title {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
        }

        .tops-card {
            background: var(--card);
            border-radius: 14px;
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .tops-tabs {
            display: flex;
            border-bottom: 1px solid var(--border);
            padding: 0 22px;
            gap: 4px;
        }

        .tops-tab {
            padding: 14px 16px;
            font-size: 13px;
            font-weight: 500;
            color: var(--muted2);
            cursor: pointer;
            border: none;
            background: none;
            font-family: 'DM Sans', sans-serif;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
            transition: all 0.15s;
        }

            .tops-tab:hover {
                color: var(--text);
            }

            .tops-tab.active {
                color: var(--green);
                border-bottom-color: var(--green);
            }

        .tops-panel {
            display: none;
            padding: 16px 22px 22px;
        }

            .tops-panel.active {
                display: block;
            }

        .top-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .top-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 10px;
            border-radius: 8px;
            transition: background 0.15s;
            cursor: pointer;
            min-width: 0;
        }

            .top-item:hover {
                background: var(--card2);
            }

        .top-rank {
            font-family: 'Syne', sans-serif;
            font-size: 12px;
            font-weight: 700;
            color: var(--muted);
            width: 18px;
            flex-shrink: 0;
            text-align: center;
        }

            .top-rank.gold {
                color: #f0b429;
            }

            .top-rank.silver {
                color: #a0aec0;
            }

            .top-rank.bronze {
                color: #c05621;
            }

        .top-img {
            width: 36px;
            height: 36px;
            border-radius: 6px;
            background: var(--card2);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            border: 1px solid var(--border);
        }

            .top-img.circle {
                border-radius: 50%;
            }

        .top-info {
            flex: 1;
            min-width: 0;
        }

        .top-name {
            font-size: 13px;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .top-sub {
            font-size: 11px;
            color: var(--muted2);
            margin-top: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .top-count {
            font-size: 11px;
            color: var(--muted);
            flex-shrink: 0;
            white-space: nowrap;
        }

        .tod-bars {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            height: 80px;
            padding-top: 8px;
        }

        .tod-bar-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .tod-bar {
            width: 100%;
            background: var(--green-glow);
            border-radius: 4px 4px 0 0;
            transition: background 0.2s;
            cursor: pointer;
            min-height: 4px;
        }

            .tod-bar:hover {
                background: var(--green);
            }

        .main::-webkit-scrollbar {
            width: 4px;
        }

        .main::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 2px;
        }

        .spotify-banner {
            background: linear-gradient(135deg, rgba(29,185,84,0.12), rgba(29,185,84,0.04));
            border: 1px solid rgba(29,185,84,0.25);
            border-radius: 14px;
            padding: 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            animation: fadeUp 0.4s ease both;
        }

        .spotify-banner-icon {
            width: 44px;
            height: 44px;
            background: rgba(29,185,84,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            animation: iconPulse 2s ease-in-out infinite;
        }

        .spotify-connected-bar {
            background: rgba(29,185,84,0.06);
            border: 1px solid rgba(29,185,84,0.15);
            border-radius: 14px;
            padding: 14px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: fadeUp 0.4s ease both;
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--green);
            flex-shrink: 0;
            animation: pulse 2s ease-in-out infinite;
        }

        .connect-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--green);
            color: #000;
            border: none;
            border-radius: 10px;
            padding: 11px 20px;
            font-size: 14px;
            font-weight: 600;
            font-family: 'DM Sans', sans-serif;
            text-decoration: none;
            transition: background 0.2s;
            white-space: nowrap;
            cursor: pointer;
        }

            .connect-btn:hover {
                background: var(--green-dim);
            }

        .dismiss-btn {
            background: none;
            border: none;
            color: var(--muted);
            font-size: 13px;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            padding: 8px;
            transition: color 0.2s;
        }

            .dismiss-btn:hover {
                color: var(--muted2);
            }

        .nav-connected {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            font-size: 14px;
            color: var(--green);
            margin-bottom: 2px;
        }

            .nav-connected svg {
                width: 16px;
                height: 16px;
                flex-shrink: 0;
            }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(12px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.85);
            }
        }

        @@keyframes iconPulse {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(0.92);
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <a class="sidebar-logo" asp-page="/Index">
                <div class="logo-icon">
                    <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                </div>
                <span class="logo-text">Statify</span>
            </a>
            <nav class="nav">
                <div class="nav-label">Menu</div>
                <a class="nav-item active" href="#top" onclick="navScroll(event,'top')">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" /></svg>
                    Dashboard
                </a>
                <a class="nav-item" asp-page="/RecentlyPlayed">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" /></svg>
                    Recently Played
                </a>
                <a class="nav-item" href="#section-tracks" onclick="navScroll(event,'section-tracks')">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z" /></svg>
                    Top Tracks
                </a>
                <a class="nav-item" href="#section-artists" onclick="navScroll(event,'section-artists')">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>
                    Top Artists
                </a>
                <a class="nav-item" href="#section-albums" onclick="navScroll(event,'section-albums')">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" /></svg>
                    Top Albums
                </a>
                <a class="nav-item" asp-page="/WorldMap">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                    World Map
                </a>
                <div class="nav-label">Spotify</div>
                @if (!Model.SpotifyConnected)
                {
                    <a class="nav-item" href="/SpotifyAuth/login" style="color:#1DB954;border:1px solid rgba(29,185,84,0.2);background:rgba(29,185,84,0.05)">
                        <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        Connect Spotify
                    </a>
                }
                else
                {
                    <div class="nav-connected">
                        <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        <span style="font-size:13px">Spotify connected</span>
                        <div class="pulse-dot" style="margin-left:auto"></div>
                    </div>
                }
                <div class="nav-label">Account</div>
                <a class="nav-item" asp-page="/Settings">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" /></svg>
                    Settings
                </a>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                    <button type="submit" class="nav-item" style="width:100%;border:none;background:none;text-align:left;cursor:pointer">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" /></svg>
                        Sign out
                    </button>
                </form>
            </nav>
            <a class="sidebar-user" asp-page="/Settings">
                <div class="user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                <div>
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-sub">@(Model.SpotifyConnected ? "Spotify connected" : "Spotify not connected")</div>
                </div>
            </a>
        </aside>

        <main class="main">
            <div class="topbar">
                <div class="page-title">Dashboard</div>
                <div class="time-filter">
                    <a class="tf-btn @(Model.Range == "7d" ? "active" : "")" href="?range=7d">7D</a>
                    <a class="tf-btn @(Model.Range == "30d" ? "active" : "")" href="?range=30d">30D</a>
                    <a class="tf-btn @(Model.Range == "6m" ? "active" : "")" href="?range=6m">6M</a>
                    <a class="tf-btn @(Model.Range is "all" or null ? "active" : "")" href="?range=all">All</a>
                </div>
            </div>

            @if (!Model.SpotifyConnected)
            {
                <div class="spotify-banner" id="spotify-banner">
                    <div style="display:flex;align-items:center;gap:16px">
                        <div class="spotify-banner-icon">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                        </div>
                        <div>
                            <div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:#f0f0f0;margin-bottom:4px">Connect your Spotify account</div>
                            <div style="font-size:13px;color:#888;line-height:1.5">Link Spotify to start tracking your listening history and unlock your full dashboard.</div>
                        </div>
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
                        <button class="dismiss-btn" onclick="document.getElementById('spotify-banner').style.display='none'">Dismiss</button>
                        <a href="/SpotifyAuth/login" class="connect-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="#000"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                            Connect Spotify
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="spotify-connected-bar">
                    <div class="pulse-dot"></div>
                    <span style="font-size:13px;color:#888">Spotify connected — your listening data is being tracked</span>
                </div>
            }

            @{
                var rangeLabel = Model.Range switch { "7d" => "Last 7 days", "30d" => "Last 30 days", "6m" => "Last 6 months", _ => "All time" };
            }
            <div class="stats-grid">
                <div class="stat-card" style="animation-delay:0s">
                    <div class="stat-card-label">Tracks played</div>
                    <div class="stat-card-val">@Model.Data.TotalTracks.ToString("N0")</div>
                    <div class="stat-card-sub">@rangeLabel</div>
                </div>
                <div class="stat-card" style="animation-delay:0.05s">
                    <div class="stat-card-label">Unique artists</div>
                    <div class="stat-card-val">@Model.Data.UniqueArtists</div>
                    <div class="stat-card-sub">@rangeLabel</div>
                </div>
                <div class="stat-card" style="animation-delay:0.1s">
                    <div class="stat-card-label">Unique albums</div>
                    <div class="stat-card-val">@Model.Data.UniqueAlbums</div>
                    <div class="stat-card-sub">@rangeLabel</div>
                </div>
                <div class="stat-card" style="animation-delay:0.15s">
                    <div class="stat-card-label">Countries</div>
                    <div class="stat-card-val">@Model.Data.UniqueCountries</div>
                    <div class="stat-card-sub">Artist origins · @rangeLabel</div>
                </div>
            </div>

            <div class="charts-row">
                <div class="card" style="animation-delay:0.2s">
                    <div class="card-header"><span class="card-title">Listening activity</span></div>
                    <canvas id="activityChart" height="100"></canvas>
                </div>
                <div class="card" style="animation-delay:0.25s">
                    <div class="card-header"><span class="card-title">Time of day</span></div>
                    <div class="tod-bars" id="todBars"></div>
                    <div style="display:flex;justify-content:space-between;margin-top:8px">
                        <span style="font-size:10px;color:var(--muted)">12am</span>
                        <span style="font-size:10px;color:var(--muted)">6am</span>
                        <span style="font-size:10px;color:var(--muted)">12pm</span>
                        <span style="font-size:10px;color:var(--muted)">6pm</span>
                        <span style="font-size:10px;color:var(--muted)">11pm</span>
                    </div>
                </div>
            </div>

            <a href="/WorldMap" style="text-decoration:none">
                <div class="card" style="display:flex;align-items:center;justify-content:space-between;padding:20px 24px;transition:border-color 0.15s" onmouseover="this.style.borderColor='rgba(29,185,84,0.3)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.07)'">
                    <div style="display:flex;align-items:center;gap:14px">
                        <div style="width:40px;height:40px;border-radius:10px;background:var(--green-glow);border:1px solid rgba(29,185,84,0.2);display:flex;align-items:center;justify-content:center">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="#1DB954"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                        </div>
                        <div>
                            <div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--text)">Listening World Map</div>
                            <div style="font-size:12px;color:var(--muted2);margin-top:2px">Explore your artist origins on an interactive 3D globe</div>
                        </div>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;color:var(--green);font-size:13px;font-weight:500">
                        Open globe
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z" /></svg>
                    </div>
                </div>
            </a>

            <div class="card" id="section-tracks">
                <div class="card-header"><span class="card-title">Top Tracks</span></div>
                <div class="top-list">
                    @for (int ti = 0; ti < Model.Data.TopTracks.Count; ti++)
                    {
                        var t = Model.Data.TopTracks[ti];
                        var n = ti + 1;
                        <div class="top-item">
                            <span class="top-rank @(n == 1 ? "gold" : n == 2 ? "silver" : n == 3 ? "bronze" : "")">@n</span>
                            <div class="top-img">🎵</div>
                            <div class="top-info">
                                <div class="top-name">@t.Name</div>
                                <div class="top-sub">@t.Sub</div>
                            </div>
                            <span class="top-count">@t.Count plays</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card" id="section-artists">
                <div class="card-header"><span class="card-title">Top Artists</span></div>
                <div class="top-list">
                    @for (int ai = 0; ai < Model.Data.TopArtists.Count; ai++)
                    {
                        var a = Model.Data.TopArtists[ai];
                        var n = ai + 1;
                        <div class="top-item">
                            <span class="top-rank @(n == 1 ? "gold" : n == 2 ? "silver" : n == 3 ? "bronze" : "")">@n</span>
                            <div class="top-img circle">👤</div>
                            <div class="top-info">
                                <div class="top-name">@a.Name</div>
                                <div class="top-sub">@a.Sub</div>
                            </div>
                            <span class="top-count">@a.Count plays</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card" id="section-albums">
                <div class="card-header"><span class="card-title">Top Albums</span></div>
                <div class="top-list">
                    @for (int li = 0; li < Model.Data.TopAlbums.Count; li++)
                    {
                        var l = Model.Data.TopAlbums[li];
                        var n = li + 1;
                        <div class="top-item">
                            <span class="top-rank @(n == 1 ? "gold" : n == 2 ? "silver" : n == 3 ? "bronze" : "")">@n</span>
                            <div class="top-img">💿</div>
                            <div class="top-info">
                                <div class="top-name">@l.Name</div>
                                <div class="top-sub">@l.Sub</div>
                            </div>
                            <span class="top-count">@l.Count plays</span>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>

    <script>
        const actLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ActivityByMonth.Select(m => m.Month).ToList()));
        const actData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ActivityByMonth.Select(m => m.Count).ToList()));
        const todData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data.ListeningByHour));

        function navScroll(e, id) {
            e.preventDefault();
            if (id === 'top') {
                document.querySelector('.main').scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                const el = document.getElementById(id);
                if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
            document.querySelectorAll('.nav-item[href]').forEach(n => n.classList.remove('active'));
            e.currentTarget.classList.add('active');
        }

        const mainEl = document.querySelector('.main');
        const scrollSections = [
            { id: 'section-tracks',  href: '#section-tracks' },
            { id: 'section-artists', href: '#section-artists' },
            { id: 'section-albums',  href: '#section-albums' },
        ];
        mainEl.addEventListener('scroll', () => {
            const scrollTop = mainEl.scrollTop;
            if (scrollTop < 100) { setNavActiveByHref('#top'); return; }
            for (let i = scrollSections.length - 1; i >= 0; i--) {
                const el = document.getElementById(scrollSections[i].id);
                if (el && el.offsetTop - 120 <= scrollTop) {
                    setNavActiveByHref(scrollSections[i].href); return;
                }
            }
        });

        function setNavActiveByHref(href) {
            document.querySelectorAll('.nav-item[href]').forEach(n => {
                n.classList.remove('active');
                if (n.getAttribute('href') === href) n.classList.add('active');
            });
        }

        const actCtx = document.getElementById('activityChart').getContext('2d');
        new Chart(actCtx, {
            type: 'line',
            data: {
                labels: actLabels,
                datasets: [{
                    data: actData,
                    borderColor: '#1DB954',
                    backgroundColor: 'rgba(29,185,84,0.08)',
                    borderWidth: 2,
                    pointRadius: 3,
                    pointBackgroundColor: '#1DB954',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#555', font: { size: 11 } } },
                    y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#555', font: { size: 11 } } }
                }
            }
        });

        const todContainer = document.getElementById('todBars');
        const maxTod = Math.max(...todData, 1);
        todData.forEach((val, i) => {
            const wrap = document.createElement('div');
            wrap.className = 'tod-bar-wrap';
            const bar = document.createElement('div');
            bar.className = 'tod-bar';
            bar.style.height = `${Math.max((val/maxTod)*70, 4)}px`;
            bar.title = `${i}:00 — ${val} plays`;
            wrap.appendChild(bar);
            todContainer.appendChild(wrap);
        });

    </script>
</body>
</html>
