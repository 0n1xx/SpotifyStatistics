@* _Sidebar.cshtml — Shared sidebar partial
   Rendered by _AppLayout.cshtml for every authenticated page.
   Reads current route, Spotify status, and user identity to highlight
   the active nav item and show the correct Spotify connection state.
*@
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject Microsoft.AspNetCore.Identity.UserManager<Microsoft.AspNetCore.Identity.IdentityUser> SidebarUserManager
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment SidebarEnv
@{
    // Current Razor Page path — used to mark the active nav item
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";

    // Passed via ViewData["SpotifyConnected"] by each page's @{ } block
    bool spotifyConnected = ViewData["SpotifyConnected"] is bool sc && sc;

    string userName    = User.Identity?.Name ?? "";
    // First letter of username shown as a fallback avatar
    string userInitial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "?";

    // Avatar URL — resolved directly from disk on every page so the sidebar
    // user card always shows the correct photo regardless of which page is active.
    // ViewData["AvatarUrl"] is used as a fast-path when already set (e.g. Settings page).
    string? avatarUrl = ViewData["AvatarUrl"] as string;
    if (avatarUrl == null)
    {
        var sidebarUserId = SidebarUserManager.GetUserId(User);
        if (sidebarUserId != null)
        {
            var avatarsDir = System.IO.Path.Combine(SidebarEnv.WebRootPath, "avatars");
            foreach (var ext in new[] { "jpg", "jpeg", "png", "gif", "webp" })
            {
                var candidate = System.IO.Path.Combine(avatarsDir, $"{sidebarUserId}.{ext}");
                if (System.IO.File.Exists(candidate))
                {
                    avatarUrl = $"/avatars/{sidebarUserId}.{ext}";
                    break;
                }
            }
        }
    }
}

@* ── Sidebar shell ── *@
<aside class="sidebar" id="sidebar">

    @* Logo — clicking navigates back to the landing page *@
    <a class="sidebar-logo" asp-page="/Index">
        <div class="logo-icon">
            @* Spotify-style waveform icon — inline SVG avoids an extra HTTP request *@
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" />
            </svg>
        </div>
        <span class="logo-text">Statify</span>
    </a>

    @* ── Main navigation ── *@
    <nav class="nav" aria-label="Main navigation">

        <p class="nav-label">Menu</p>

        @* Dashboard — overview stats, charts, and top lists *@
        <a class="nav-item @(currentPage == "/Dashboard" ? "active" : "")" asp-page="/Dashboard">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" /></svg>
            Dashboard
        </a>

        @* Recently Played — full paginated listening history *@
        <a class="nav-item @(currentPage == "/RecentlyPlayed" ? "active" : "")" asp-page="/RecentlyPlayed">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" /></svg>
            Recently Played
        </a>

        @* ── Section scroll links (Top Tracks / Artists / Albums) ────────────
           These link to anchored sections inside the Dashboard page.
           
           TWO DIFFERENT BEHAVIOURS depending on the current page:
           
           ① ON Dashboard: use onclick="navScroll()" for smooth in-page scroll.
              navScroll() is defined in dashboard.js and prevents the default
              anchor jump (which wouldn't work because .main is the scroll
              container, not the window).
           
           ② ON any other page: use a plain Razor anchor link that navigates
              to /Dashboard#section-* and lets dashboard.js auto-scroll on load.
              We can't call navScroll() here because dashboard.js is not loaded.
        *@
        @if (currentPage == "/Dashboard")
        {
            <a class="nav-item" href="#section-tracks" onclick="navScroll(event,'section-tracks')">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z" /></svg>
                Top Tracks
            </a>

            <a class="nav-item" href="#section-artists" onclick="navScroll(event,'section-artists')">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>
                Top Artists
            </a>

            <a class="nav-item" href="#section-albums" onclick="navScroll(event,'section-albums')">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" /></svg>
                Top Albums
            </a>
        }
        else
        {
            @* Navigate to Dashboard first, then the browser delivers the hash.
               dashboard.js reads location.hash on DOMContentLoaded and scrolls. *@
            <a class="nav-item" asp-page="/Dashboard" asp-fragment="section-tracks">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z" /></svg>
                Top Tracks
            </a>

            <a class="nav-item" asp-page="/Dashboard" asp-fragment="section-artists">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" /></svg>
                Top Artists
            </a>

            <a class="nav-item" asp-page="/Dashboard" asp-fragment="section-albums">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" /></svg>
                Top Albums
            </a>
        }

        @* World Map — D3 choropleth of artist origins *@
        <a class="nav-item @(currentPage == "/WorldMap" ? "active" : "")" asp-page="/WorldMap">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
            World Map
        </a>

        <p class="nav-label">Spotify</p>

        @* ── Spotify connection item — two states: connect prompt or connected badge ── *@
        @if (!spotifyConnected)
        {
            @* Not connected — styled as a green CTA to prompt the user to link Spotify *@
            <a class="nav-item" href="/SpotifyAuth/login" style="color:#1DB954;border:1px solid rgba(29,185,84,0.2);background:rgba(29,185,84,0.05)">
                <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                Connect Spotify
            </a>
        }
        else
        {
            @* Connected — read-only status row with a pulsing green dot *@
            <div class="nav-connected">
                <svg viewBox="0 0 24 24" fill="#1DB954" style="opacity:1" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.65 14.4c-.2.3-.6.4-.9.2-2.5-1.53-5.63-1.87-9.33-1.03-.36.08-.72-.15-.8-.5-.08-.36.15-.72.5-.8 4.05-.92 7.52-.53 10.33 1.2.3.18.4.58.2.93zm1.24-2.75c-.25.38-.75.5-1.13.25-2.85-1.75-7.2-2.26-10.57-1.23-.43.13-.9-.1-1.03-.53-.13-.43.1-.9.53-1.03 3.85-1.17 8.63-.6 11.93 1.41.37.23.5.73.27 1.13zm.1-2.86C14.5 8.9 8.68 8.7 5.2 9.73c-.52.16-1.07-.14-1.23-.65-.16-.52.14-1.07.65-1.23 4-.22 10.35.43 14.43 2.85.46.27.62.86.35 1.32-.27.45-.87.6-1.32.34l-.09-.07z" /></svg>
                <span style="font-size:13px">Spotify connected</span>
                @* Pulse animation defined in app.css → @keyframes pulse *@
                <div class="pulse-dot" style="margin-left:auto"></div>
            </div>
        }

        <p class="nav-label">Account</p>

        @* Settings page — account, connections, danger zone *@
        <a class="nav-item @(currentPage == "/Settings" ? "active" : "")" asp-page="/Settings">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" /></svg>
            Settings
        </a>

        @* Sign out — POST to ASP.NET Identity logout endpoint, redirects to landing page *@
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
            <button type="submit" class="nav-item" style="width:100%;border:none;background:none;text-align:left;cursor:pointer">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" /></svg>
                Sign out
            </button>
        </form>

    </nav>

    @* ── User card — bottom of sidebar, links to Settings ── *@
    @* Shows the profile photo when set (ViewData["AvatarUrl"]), otherwise the initial
       letter — identical fallback logic as the avatar-large on Settings.cshtml so the
       two always match. *@
    <a class="sidebar-user" asp-page="/Settings">
        <div class="user-avatar">
            @if (avatarUrl != null)
            {
                <img src="@avatarUrl" alt="Profile photo">
            }
            else
            {
                @userInitial
            }
        </div>
        <div>
            <div class="user-name">@userName</div>
            <div class="user-sub">@(spotifyConnected ? "Spotify connected" : "Spotify not connected")</div>
        </div>
    </a>

</aside>
