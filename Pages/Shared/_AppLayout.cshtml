@* _AppLayout.cshtml — Shared layout for all authenticated app pages
   Every page that sets Layout = "~/Pages/Shared/_AppLayout.cshtml" goes through here.
   Responsibilities:
     - <head> with fonts, global CSS, and optional per-page CSS / CDN scripts
     - Two-column app shell: sidebar partial (left) + page body (right)
     - Optional per-page JS injected just before </body>
*@
@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Statify";

    // Set in each page's @{ } block — path to a page-specific stylesheet
    var extraCss  = ViewData["ExtraCss"]?.ToString()  ?? "";

    // Set in each page's @{ } block — path to a page-specific script file
    var extraJs   = ViewData["ExtraJs"]?.ToString()   ?? "";

    // Set in each page's @{ } block — raw HTML injected into <head> (e.g. CDN libraries like Chart.js, D3)
    var extraHead = ViewData["ExtraHead"]?.ToString()  ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@pageTitle — Statify</title>

    @* Google Fonts — Syne for headings, DM Sans for body text *@
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

    @* Global styles — app shell grid, sidebar, shared components, animations *@
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    @* Page-specific stylesheet (e.g. ~/css/dashboard.css) — only loaded when set by the page *@
    @if (!string.IsNullOrEmpty(extraCss))
    {
        <link rel="stylesheet" href="@extraCss" asp-append-version="true" />
    }

    @* Extra <head> content injected verbatim — CDN libraries like Chart.js, D3, TopoJSON *@
    @if (!string.IsNullOrEmpty(extraHead))
    {
        @Html.Raw(extraHead)
    }
</head>
<body>

    @* ── Hamburger button — hidden on desktop (>900px), visible on tablet/mobile ── *@
    @* Toggles .sidebar.open via sidebar.js *@
    <button class="hamburger" id="hamburger-btn"
            aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
    </button>

    @* ── Overlay — dims the page content behind the open sidebar drawer ── *@
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    @* ── Two-column app shell: sidebar | page content ── *@
    @* CSS grid defined in app.css → .app { grid-template-columns: var(--sidebar) 1fr } *@
    <div class="app">

        @* Sidebar partial — logo, navigation links, Spotify status, user card *@
        @* Reads SpotifyConnected from ViewData and current user from User.Identity *@
        <partial name="Partials/_Sidebar" />

        @* Page content — each .cshtml renders its own <main class="main"> here *@
        @RenderBody()

    </div>

    @* Page-specific JS (e.g. ~/js/dashboard.js) — loaded after the DOM so it can query elements *@
    @if (!string.IsNullOrEmpty(extraJs))
    {
        <script src="@extraJs" asp-append-version="true"></script>
    }

    @* Sidebar hamburger toggle — handles mobile drawer open/close *@
    <script src="~/js/sidebar.js" asp-append-version="true"></script>

    @* Inline <script> blocks injected by individual pages (e.g. JSON-serialised model data for charts) *@
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
