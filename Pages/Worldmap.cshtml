@page
@model SpotifyStatisticsWebApp.Pages.WorldMapModel
@{
    ViewData["Title"]    = "World Map";
    ViewData["ExtraCss"] = "~/css/worldmap.css";
    ViewData["ExtraJs"]  = "~/js/worldmap.js";
    ViewData["ExtraHead"] = "<script src=\"https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js\"></script><script src=\"https://cdn.jsdelivr.net/npm/topojson-client@3/dist/topojson-client.min.js\"></script>";
    ViewData["SpotifyConnected"] = Model.SpotifyConnected;
    Layout = "~/Pages/Shared/_AppLayout.cshtml";
}

<main class="main">
    <div class="page-header">
        <div>
            <h1 class="page-title">World Map</h1>
            <p class="page-sub">Artist origins across your listening history</p>
        </div>
        <div style="font-size:13px;color:var(--muted2)">
            <strong style="color:var(--text)">@Model.CountryCounts.Count</strong> countries
            &middot;
            <strong style="color:var(--text)">@Model.CountryCounts.Sum(c => c.Count).ToString("N0")</strong> plays
        </div>
    </div>

    <div class="map-area">
        <svg id="world-map-svg"></svg>

        <div class="country-panel">
            <div class="country-panel-header">Top Countries</div>
            <div class="country-list">
                @{ int maxPlays = Model.CountryCounts.FirstOrDefault()?.Count ?? 1; }
                @foreach (var c in Model.CountryCounts.Take(15))
                {
                    double pct = (double)c.Count / maxPlays * 100;
                    <div class="country-row">
                        <span class="country-name">@c.Country</span>
                        <div class="country-bar-wrap">
                            <div class="country-bar" style="width:@pct.ToString("F0")%"></div>
                        </div>
                        <span class="country-plays">@c.Count</span>
                    </div>
                }
            </div>
        </div>

        <div id="map-tooltip">
            <div class="tt-name"></div>
            <div class="tt-plays"></div>
        </div>

        <div class="map-legend">
            <div class="legend-gradient"></div>
            <span>Listening intensity</span>
        </div>

        <div class="zoom-controls">
            <div class="zoom-btn" id="zoom-in">+</div>
            <div class="zoom-btn" id="zoom-out">&minus;</div>
            <div class="zoom-btn" id="zoom-reset" style="font-size:12px;font-weight:700">&#8962;</div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        const countryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.CountryCounts.ToDictionary(c => c.Country ?? "unknown", c => c.Count)
        ));
    </script>
}
